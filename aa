	local classLabel = Instance.new("TextLabel")
	classLabel.BackgroundTransparency = 1
	classLabel.AnchorPoint = Vector2.new(1, 0.5)
	classLabel.Position = UDim2.new(1, -8, 0.5, 0)
	classLabel.Size = UDim2.fromOffset(150, 18)
	classLabel.Font = Enum.Font.Gotham
	classLabel.Text = inst.ClassName
	classLabel.TextColor3 = Color3.fromRGB(170,170,175)
	classLabel.TextSize = 11
	classLabel.TextXAlignment = Enum.TextXAlignment.Right
	classLabel.TextTruncate = Enum.TextTruncate.AtEnd
	classLabel.Parent = row

	local childWrap = Instance.new("Frame")
	childWrap.Name = "Children"
	childWrap.BackgroundTransparency = 1
	childWrap.Size = UDim2.new(1, 0, 0, 0)
	childWrap.AutomaticSize = Enum.AutomaticSize.Y
	childWrap.Visible = canExpand and isExpanded
	childWrap.Parent = container

	local childPad = Instance.new("UIPadding")
	childPad.PaddingLeft = UDim.new(0, 14)
	childPad.Parent = childWrap

	local childLayout = Instance.new("UIListLayout")
	childLayout.Padding = UDim.new(0, 2)
	childLayout.SortOrder = Enum.SortOrder.LayoutOrder
	childLayout.Parent = childWrap

	if canExpand then
		arrow.Text = isExpanded and "▼" or "▶"
	else
		arrow.Text = " "
	end

	row.MouseButton1Click:Connect(function()
		applySelection(inst)
		if canExpand then
			expanded[inst] = not expanded[inst]
			refreshQueued = false
			clearTree()
			refreshQueued = true
			task.defer(function()
				refreshQueued = false
				refreshTree()
			end)
		end
	end)

	if canExpand and isExpanded then
		for _, child in ipairs(children) do
			renderNode(childWrap, child, depth + 1, q)
		end
	end
end

function refreshTree()
	clearTree()
	pathLabel.Text = "Path: " .. root:GetFullName()
	pathBox.Text = (selected and pcall(function() return selected.Name end)) and selected:GetFullName() or root:GetFullName()
	for _, child in ipairs(safeGetChildren(root)) do
		renderNode(tree, child, 0, searchText)
	end
	if selected and not pcall(function() return selected.Name end) then
		selected = nil
		updateProperties(nil)
	end
end

local function refreshServices()
	clearServices()
	for index, serviceName in ipairs(SERVICES) do
		local ok, service = pcall(function() return game:GetService(serviceName) end)
		if ok and service then
			local btn = Instance.new("TextButton")
			btn.Name = serviceName
			btn.LayoutOrder = index
			btn.Size = UDim2.new(1, 0, 0, 28)
			btn.BackgroundColor3 = (service == root) and Color3.fromRGB(60,80,110) or Color3.fromRGB(40,40,45)
			btn.BorderSizePixel = 0
			btn.Text = serviceName
			btn.Font = Enum.Font.GothamSemibold
			btn.TextSize = 12
			btn.TextColor3 = Color3.fromRGB(245,245,245)
			btn.Parent = servicesList
			local c = Instance.new("UICorner")
			c.CornerRadius = UDim.new(0, 8)
			c.Parent = btn
			btn.MouseButton1Click:Connect(function()
				root = service
				selected = nil
				pathLabel.Text = "Path: " .. service:GetFullName()
				pathBox.Text = service:GetFullName()
				refreshServices()
				refreshTree()
				updateProperties(nil)
			end)
		end
	end
end

local function queueRefresh()
	if refreshQueued then return end
	refreshQueued = true
	task.defer(function()
		refreshQueued = false
		refreshServices()
		refreshTree()
	end)
end

local function expandAll(inst)
	if isScriptInstance(inst) then return end
	local children = safeGetChildren(inst)
	if #children == 0 then return end
	expanded[inst] = true
	for _, child in ipairs(children) do
		expandAll(child)
	end
end

local function collapseAll()
	expanded = setmetatable({}, { __mode = "k" })
end

-- ربط الأزرار
refreshBtn.MouseButton1Click:Connect(queueRefresh)
expandAllBtn.MouseButton1Click:Connect(function()
	collapseAll()
	expandAll(root)
	refreshTree()
end)
collapseAllBtn.MouseButton1Click:Connect(function()
	collapseAll()
	refreshTree()
end)
disableRemotesBtn.MouseButton1Click:Connect(disableAllRemotes)
filterRemotesBtn.MouseButton1Click:Connect(function()
	filterRemotesOnly = true
	updateTotalRemotes()
	refreshTree()
end)
resetFilterBtn.MouseButton1Click:Connect(function()
	filterRemotesOnly = false
	updateTotalRemotes()
	refreshTree()
end)
searchBox:GetPropertyChangedSignal("Text"):Connect(function()
	searchText = searchBox.Text
	refreshTree()
end)
pathBox.FocusLost:Connect(function()
	if selected and pcall(function() return selected.Name end) then
		pathBox.Text = selected:GetFullName()
	else
		pathBox.Text = root:GetFullName()
	end
end)

-- تحديث عداد الريموتات دورياً
task.spawn(function()
	while true do
		updateTotalRemotes()
		task.wait(5)
	end
end)

-- بدء التشغيل
refreshServices()
refreshTree()
applySelection(root)
updateTotalRemotes()

-- مراقبة التغييرات في الشجرة
root.DescendantAdded:Connect(queueRefresh)
root.DescendantRemoving:Connect(queueRefresh)
game.DescendantAdded:Connect(function(inst)
	if inst == root or inst:IsDescendantOf(root) then queueRefresh() end
end)
game.DescendantRemoving:Connect(function(inst)
	if inst == root or inst:IsDescendantOf(root) then queueRefresh() end
end)
