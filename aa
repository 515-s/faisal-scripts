-- ========== دوال مساعدة ==========
local function safeGetChildren(inst)
	local ok, children = pcall(function() return inst:GetChildren() end)
	if ok and type(children) == "table" then return children end
	return {}
end

local function safeGetAttributes(inst)
	local ok, attrs = pcall(function() return inst:GetAttributes() end)
	if ok and type(attrs) == "table" then return attrs end
	return {}
end

local function isScriptInstance(inst)
	return SCRIPT_CLASSES[inst.ClassName] == true
end

local function isRemote(inst)
	return inst:IsA("RemoteEvent") or inst:IsA("RemoteFunction")
end

local function getClassBadge(inst)
	if inst:IsA("Folder") or inst:IsA("Model") then return "📁" end
	if inst:IsA("Part") then return "🧱" end
	if isScriptInstance(inst) then return "🧩" end
	if isRemote(inst) then return "⚠️" end
	return "•"
end

-- تحديث عداد الريموتات
local function updateTotalRemotes()
	local count = 0
	for _, obj in ipairs(game:GetDescendants()) do
		if isRemote(obj) then count += 1 end
	end
	totalRemotes = count
	statusBar.Text = string.format("Total Remotes: %d | Filter: %s", totalRemotes, filterRemotesOnly and "Remotes Only" or "All")
end

-- تعطيل جميع الريموتات
local function disableAllRemotes()
	local count = 0
	for _, obj in ipairs(game:GetDescendants()) do
		if isRemote(obj) then
			pcall(function()
				obj.Name = "i dont know"
				count += 1
			end)
		end
	end
	statusBar.Text = string.format("Disabled %d remotes.", count)
	task.wait(1)
	updateTotalRemotes()
	queueRefresh()
end

-- دوال البحث والفلترة
local function matchesQuery(inst, q)
	if q == "" then return true end
	local s = string.lower(q)
	return string.find(string.lower(inst.Name), s, 1, true) ~= nil
		or string.find(string.lower(inst.ClassName), s, 1, true) ~= nil
end

local function subtreeMatches(inst, q)
	if matchesQuery(inst, q) then return true end
	for _, child in ipairs(safeGetChildren(inst)) do
		if subtreeMatches(child, q) then return true end
	end
	return false
end

local function shouldShow(inst, q)
	if filterRemotesOnly and not isRemote(inst) then return false end
	if q == "" then return true end
	return subtreeMatches(inst, q)
end

