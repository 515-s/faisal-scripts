local function isScriptInstance(inst: Instance): boolean
	return SCRIPT_CLASSES[inst.ClassName] == true
end

local function safeGetChildren(inst: Instance): {Instance}
	local ok, children = pcall(function()
		return inst:GetChildren()
	end)
	if ok and type(children) == "table" then
		return children
	end
	return {}
end

local function safeGetAttributes(inst: Instance): {[string]: any}
	local ok, attrs = pcall(function()
		return inst:GetAttributes()
	end)
	if ok and type(attrs) == "table" then
		return attrs
	end
	return {}
end

local function safeCount(inst: Instance): number
	return #safeGetChildren(inst)
end

local function getClassBadge(inst: Instance): string
	if inst:IsA("Folder") or inst:IsA("Model") then
		return "📁"
	end
	if inst:IsA("Part") then
		return "🧱"
	end
	if isScriptInstance(inst) then
		return "🧩"
	end
	return "•"
end

local function matchesQuery(inst: Instance, q: string): boolean
	if q == "" then
		return true
	end
	local s = string.lower(q)
	return string.find(string.lower(inst.Name), s, 1, true) ~= nil
		or string.find(string.lower(inst.ClassName), s, 1, true) ~= nil
end

local function subtreeMatches(inst: Instance, q: string): boolean
	if matchesQuery(inst, q) then
		return true
	end
	for _, child in ipairs(safeGetChildren(inst)) do
		if subtreeMatches(child, q) then
			return true
		end
	end
	return false
end

local function isAlive(inst: Instance?): boolean
	if inst == nil then
		return false
	end
	local ok = pcall(function()
		local _ = inst.Name
	end)
	return ok
end

local function updateProperties(inst: Instance?)
	clearProperties()

	local header = Instance.new("TextLabel")
	header.BackgroundTransparency = 1
	header.Size = UDim2.new(1, 0, 0, 18)
	header.Font = Enum.Font.GothamSemibold
	header.Text = inst and inst.Name or "None selected"
	header.TextColor3 = Color3.fromRGB(245, 245, 245)
	header.TextSize = 13
	header.TextXAlignment = Enum.TextXAlignment.Left
	header.TextTruncate = Enum.TextTruncate.AtEnd
	header.Parent = propsScroll

	local function addLine(label: string, value: string)
		local row = Instance.new("TextLabel")
		row.BackgroundTransparency = 1
		row.Size = UDim2.new(1, 0, 0, 18)
		row.AutomaticSize = Enum.AutomaticSize.Y
		row.Font = Enum.Font.Gotham
		row.TextSize = 12
		row.TextColor3 = Color3.fromRGB(220, 220, 225)
		row.TextXAlignment = Enum.TextXAlignment.Left
		row.TextYAlignment = Enum.TextYAlignment.Top
		row.TextWrapped = true
		row.Text = label .. ": " .. value
		row.Parent = propsScroll
	end

	if not inst or not isAlive(inst) then
		addLine("Info", "Select an item to see properties.")
		return
	end

	local parentName = "nil"
	local okParent, parentObj = pcall(function()
		return inst.Parent
	end)
	if okParent and parentObj then
		parentName = parentObj:GetFullName()
	end

	local childCount = tostring(safeCount(inst))

	local archivable = "N/A"
	pcall(function()
		archivable = tostring((inst :: any).Archivable)
	end)

	local locked = "N/A"
	pcall(function()
		locked = tostring((inst :: any).Locked)
	end)

	addLine("Name", inst.Name)
	addLine("Class", inst.ClassName)
	addLine("FullName", inst:GetFullName())
	addLine("Parent", parentName)
	addLine("Children", childCount)
	addLine("Archivable", archivable)
	addLine("Locked", locked)

	local attrs = safeGetAttributes(inst)
	local keys = {}
	for k in pairs(attrs) do
		table.insert(keys, k)
	end
	table.sort(keys)

	if #keys == 0 then
		addLine("Attributes", "none")
	else
		local lines = {}
		for _, key in ipairs(keys) do
			local value = attrs[key]
			table.insert(lines, key .. " = " .. tostring(value))
		end
		addLine("Attributes", table.concat(lines, "\n"))
	end
end

local function applySelection(inst: Instance?)
	selected = inst
	if inst then
		pathBox.Text = inst:GetFullName()
		pathLabel.Text = "Path: " .. inst:GetFullName()
	else
		pathBox.Text = ""
		pathLabel.Text = "Path: " .. root:GetFullName()
	end
	updateProperties(inst)
	clearTree()
end

local function renderNode(parentGui: Instance, inst: Instance, depth: number, q: string)
	if q ~= "" and not subtreeMatches(inst, q) then
		return
	end

	local container = Instance.new("Frame")
	container.Name = "Node_" .. inst.Name
	container.BackgroundTransparency = 1
	container.Size = UDim2.new(1, 0, 0, 0)
	container.AutomaticSize = Enum.AutomaticSize.Y
	container.Parent = parentGui

	local row = Instance.new("TextButton")
	row.Name = "Row"
	row.AutoButtonColor = false
	row.BackgroundColor3 = (selected == inst) and Color3.fromRGB(60, 84, 122) or Color3.fromRGB(38, 38, 43)
	row.BorderSizePixel = 0
	row.Size = UDim2.new(1, 0, 0, 28)
	row.Text = ""
	row.Parent = container

	local rowCorner = Instance.new("UICorner")
	rowCorner.CornerRadius = UDim.new(0, 8)
	rowCorner.Parent = row

	local rowPad = Instance.new("UIPadding")
	rowPad.PaddingLeft = UDim.new(0, 8 + depth * 16)
	rowPad.PaddingRight = UDim.new(0, 8)
	rowPad.Parent = row

	local arrow = Instance.new("TextLabel")
	arrow.BackgroundTransparency = 1
	arrow.Size = UDim2.fromOffset(16, 28)
	arrow.Font = Enum.Font.GothamSemibold
	arrow.Text = ""
	arrow.TextColor3 = Color3.fromRGB(210, 210, 215)
	arrow.TextSize = 12
	arrow.Parent = row

	local icon = Instance.new("TextLabel")
	icon.BackgroundTransparency = 1
	icon.Position = UDim2.fromOffset(16, 0)
	icon.Size = UDim2.fromOffset(20, 28)
	icon.Font = Enum.Font.GothamSemibold
	icon.Text = getClassBadge(inst)
	icon.TextColor3 = Color3.fromRGB(235, 235, 235)
	icon.TextSize = 13
	icon.Parent = row

	local children = safeGetChildren(inst)
	local canExpand = (#children > 0) and (not isScriptInstance(inst))
	local isExpanded = expanded[inst] == true or q ~= ""

	local displayName = inst.Name
	if canExpand then
		displayName = string.format("%s (%d)", inst.Name, #children)
	end

	local nameLabel = Instance.new("TextLabel")
	nameLabel.BackgroundTransparency = 1
	nameLabel.Position = UDim2.fromOffset(38, 0)
	nameLabel.Size = UDim2.new(1, -92, 1, 0)
	nameLabel.Font = Enum.Font.Gotham
	nameLabel.Text = displayName
	nameLabel.TextColor3 = Color3.fromRGB(245, 245, 245)
	nameLabel.TextSize = 13
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
	nameLabel.Parent = row

	local classLabel = Instance.new("TextLabel")
	classLabel.BackgroundTransparency = 1
	classLabel.AnchorPoint = Vector2.new(1, 0.5)
	classLabel.Position = UDim2.new(1, -8, 0.5, 0)
	classLabel.Size = UDim2.fromOffset(150, 18)
	classLabel.Font = Enum.Font.Gotham
	classLabel.Text = inst.ClassName
	classLabel.TextColor3 = Color3.fromRGB(170, 170, 175)
	classLabel.TextSize = 11
	classLabel.TextXAlignment = Enum.TextXAlignment.Right
	classLabel.TextTruncate = Enum.TextTruncate.AtEnd
	classLabel.Parent = row

	local childWrap = Instance.new("Frame")
	childWrap.Name = "Children"
	childWrap.BackgroundTransparency = 1
	childWrap.Size = UDim2.new(1, 0, 0, 0)
	childWrap.AutomaticSize = Enum.AutomaticSize.Y
	childWrap.Visible = canExpand and isExpanded
	childWrap.Parent = container

	local childPad = Instance.new("UIPadding")
	childPad.PaddingLeft = UDim.new(0, 14)
	childPad.Parent = childWrap

	local childLayout = Instance.new("UIListLayout")
	childLayout.Padding = UDim.new(0, 2)
	childLayout.SortOrder = Enum.SortOrder.LayoutOrder
	childLayout.Parent = childWrap

	if canExpand then
		arrow.Text = isExpanded and "▼" or "▶"
	else
		arrow.Text = " "
	end

	row.MouseButton1Click:Connect(function()
		applySelection(inst)

		if canExpand then
			expanded[inst] = not expanded[inst]
			refreshQueued = false
			clearTree()
			refreshQueued = true
			task.defer(function()
				refreshQueued = false
				refreshTree()
			end)
		end
	end)

	if canExpand and isExpanded then
		for _, child in ipairs(children) do
			renderNode(childWrap, child, depth + 1, q)
		end
	end
end

function refreshTree()
	clearTree()
	pathLabel.Text = "Path: " .. root:GetFullName()
	pathBox.Text = (selected and isAlive(selected)) and selected:GetFullName() or root:GetFullName()

	for _, child in ipairs(safeGetChildren(root)) do
		renderNode(tree, child, 0, searchText)
	end

	if selected and not isAlive(selected) then
		selected = nil
		updateProperties(nil)
	end
end

local function refreshServices()
	clearServices()

	for index, serviceName in ipairs(SERVICES) do
		local ok, service = pcall(function()
			return game:GetService(serviceName)
		end)

		if ok and service then
			local btn = Instance.new("TextButton")
			btn.Name = serviceName
			btn.LayoutOrder = index
			btn.Size = UDim2.new(1, 0, 0, 28)
			btn.BackgroundColor3 = (service == root) and Color3.fromRGB(60, 80, 110) or Color3.fromRGB(40, 40, 45)
			btn.BorderSizePixel = 0
			btn.Text = serviceName
			btn.Font = Enum.Font.GothamSemibold
			btn.TextSize = 12
			btn.TextColor3 = Color3.fromRGB(245, 245, 245)
			btn.Parent = servicesList

			local c = Instance.new("UICorner")
			c.CornerRadius = UDim.new(0, 8)
			c.Parent = btn

			btn.MouseButton1Click:Connect(function()
				root = service
				selected = nil
				pathLabel.Text = "Path: " .. service:GetFullName()
				pathBox.Text = service:GetFullName()
				refreshServices()
				refreshTree()
				updateProperties(nil)
			end)
		end
	end
end

local function queueRefresh()
	if refreshQueued then
		return
	end
	refreshQueued = true
	task.defer(function()
		refreshQueued = false
		refreshServices()
		refreshTree()
	end)
end

local function expandAll(inst: Instance)
	if isScriptInstance(inst) then
		return
	end
	local children = safeGetChildren(inst)
	if #children == 0 then
		return
	end
	expanded[inst] = true
	for _, child in ipairs(children) do
		expandAll(child)
	end
end

local function collapseAll()
	expanded = setmetatable({}, { __mode = "k" }) :: {[Instance]: boolean}
end

refreshButton.MouseButton1Click:Connect(function()
	queueRefresh()
end)

expandAllButton.MouseButton1Click:Connect(function()
	collapseAll()
	expandAll(root)
	refreshTree()
end)

collapseAllButton.MouseButton1Click:Connect(function()
	collapseAll()
	refreshTree()
end)

search:GetPropertyChangedSignal("Text"):Connect(function()
	searchText = search.Text
	refreshTree()
end)

pathBox.FocusLost:Connect(function()
	-- keeps the field stable even if edited
	if selected and isAlive(selected) then
		pathBox.Text = selected:GetFullName()
	else
		pathBox.Text = root:GetFullName()
	end
end)

refreshServices()
refreshTree()
applySelection(root)

root.DescendantAdded:Connect(queueRefresh)
root.DescendantRemoving:Connect(queueRefresh)

game.DescendantAdded:Connect(function(inst)
	if inst == root or inst:IsDescendantOf(root) then
		queueRefresh()
	end
end)

game.DescendantRemoving:Connect(function(inst)
	if inst == root or inst:IsDescendantOf(root) then
		queueRefresh()
	end
end)
