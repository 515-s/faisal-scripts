local activeTags = {}
local scanning = false
local periodicConnection = nil
local signatureAttribute = "IsRealPlayer_Ultimate"

local function addSignatureToCharacter(char)
    if not char then return end
    if char:GetAttribute(signatureAttribute) then return end
    char:SetAttribute(signatureAttribute, true)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp and not hrp:FindFirstChild("RealSignaturePart") then
        local sig = Instance.new("Part")
        sig.Name = "RealSignaturePart"
        sig.Size = Vector3.new(0.1,0.1,0.1)
        sig.Transparency = 1
        sig.CanCollide = false
        sig.Parent = hrp
    end
end

local function isRealCharacter(model)
    if not model:IsA("Model") then return false, nil end
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character == model then
            return true, plr
        end
    end
    if model:GetAttribute(signatureAttribute) then
        local plr = Players:FindFirstChild(model.Name)
        if plr then return true, plr end
    end
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if hrp and hrp:FindFirstChild("RealSignaturePart") then
        local plr = Players:FindFirstChild(model.Name)
        if plr then return true, plr end
    end
    if hrp and hrp:GetNetworkOwner() == nil then
        local plr = Players:FindFirstChild(model.Name)
        if plr then return true, plr end
    end
    local hum = model:FindFirstChildOfClass("Humanoid")
    if hum and hum:FindFirstChildOfClass("Animator") then
        local plr = Players:FindFirstChild(model.Name)
        if plr then return true, plr end
    end
    return false, nil
end

local function getRealPlayerTeam(plr)
    if not plr then return nil, nil end
    local team = plr.Team
    if not team then return nil, nil end
    local tname = team.Name
    local lower = tname:lower()
    if lower:find("sheriff") then
        return "Sheriff", Color3.fromRGB(0, 150, 255)
    elseif lower:find("criminal") or lower:find("crim") then
        return "Criminal", Color3.fromRGB(255, 50, 50)
    end
    return nil, nil
end

local function getNPCTeam(model)
    local name = model.Name:lower()
    if name:find("sheriff") or name:find("sheriffs") then
        return "Sheriff", Color3.fromRGB(0, 150, 255)
    elseif name:find("criminal") or name:find("criminals") or name:find("crim") then
        return "Criminal", Color3.fromRGB(255, 50, 50)
    end
    local parent = model.Parent
    while parent do
        local pname = parent.Name:lower()
        if pname == "sheriffs" then
            return "Sheriff", Color3.fromRGB(0, 150, 255)
        elseif pname == "criminals" then
            return "Criminal", Color3.fromRGB(255, 50, 50)
        end
        parent = parent.Parent
    end
    return nil, nil
end

local function createTagOnHead(head, text, color)
    local existing = head:FindFirstChild("ProUI2Tag")
    if existing then existing:Destroy() end
    local bill = Instance.new("BillboardGui")
    bill.Name = "ProUI2Tag"
    bill.Size = UDim2.new(0, 160, 0, 45)
    bill.StudsOffset = Vector3.new(0, 3.5, 0)
    bill.AlwaysOnTop = true
    bill.Parent = head
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,1,0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold
    label.TextColor3 = color
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.new(0,0,0)
    label.Parent = bill
    return bill
end

local function fullUpdate()
    if not scanning then return end
    local newActive = {}
    local processedModels = {}

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            local char = plr.Character
            if char then
                local head = char:FindFirstChild("Head")
                if head then
                    local teamName, color = getRealPlayerTeam(plr)
                    if teamName then
                        local existing = activeTags[char]
                        if existing and existing.Parent == head then
                            newActive[char] = existing
                        else
                            if existing then existing:Destroy() end
                            newActive[char] = createTagOnHead(head, teamName, color)
                        end
                    else
                        if activeTags[char] then activeTags[char]:Destroy() end
                    end
                end
                processedModels[char] = true
            end
        end
    end

    for _, model in ipairs(workspace:GetDescendants()) do
        if model:IsA("Model") and model:FindFirstChild("Head") and model:FindFirstChildOfClass("Humanoid") then
            if not processedModels[model] then
                local isReal, _ = isRealCharacter(model)
                local head = model.Head
                if not isReal then
                    local playerWithSameName = Players:FindFirstChild(model.Name)
                    if playerWithSameName then
                        local existing = activeTags[model]
                        if existing and existing.Parent == head then
                            newActive[model] = existing
                        else
                            if existing then existing:Destroy() end
                            newActive[model] = createTagOnHead(head, "FAKE", Color3.fromRGB(255, 0, 0))
                        end
                    else
                        local teamName, color = getNPCTeam(model)
                        if teamName then
                            local existing = activeTags[model]
                            if existing and existing.Parent == head then
                                newActive[model] = existing
                            else
                                if existing then existing:Destroy() end
                                newActive[model] = createTagOnHead(head, teamName, color)
                            end
                        else
                            if activeTags[model] then activeTags[model]:Destroy() end
                        end
                    end
                end
            end
        end
    end

    for obj, tag in pairs(activeTags) do
        if not newActive[obj] then
            tag:Destroy()
            activeTags[obj] = nil
        end
    end
    for obj, tag in pairs(newActive) do
        activeTags[obj] = tag
    end
end

-- Events
local function ensureSignatureOnPlayer(plr)
    if plr == player then return end
    local char = plr.Character
    if char then
        addSignatureToCharacter(char)
    end
    plr.CharacterAdded:Connect(function(newChar)
        task.wait(0.2)
        addSignatureToCharacter(newChar)
        if scanning then fullUpdate() end
    end)
end

for _, plr in ipairs(Players:GetPlayers()) do
    ensureSignatureOnPlayer(plr)
end
Players.PlayerAdded:Connect(ensureSignatureOnPlayer)

workspace.DescendantAdded:Connect(function(desc)
    if scanning and desc:IsA("Model") and desc:FindFirstChild("Head") and desc:FindFirstChildOfClass("Humanoid") then
        task.wait(0.2)
        fullUpdate()
    end
end)

local function onTeamChange(plr)
    if scanning then fullUpdate() end
end
for _, plr in ipairs(Players:GetPlayers()) do
    if plr ~= player then
        plr:GetPropertyChangedSignal("Team"):Connect(function()
            onTeamChange(plr)
        end)
    end
end
Players.PlayerAdded:Connect(function(plr)
    if plr ~= player then
        plr:GetPropertyChangedSignal("Team"):Connect(function()
            onTeamChange(plr)
        end)
    end
end)

local function startPeriodic()
    if periodicConnection then return end
    periodicConnection = RunService.Heartbeat:Connect(function()
        if not scanning then return end
        if not periodicConnection.last then periodicConnection.last = os.clock() end
        if os.clock() - periodicConnection.last >= 3 then
            fullUpdate()
            periodicConnection.last = os.clock()
        end
    end)
end
local function stopPeriodic()
    if periodicConnection then
        periodicConnection:Disconnect()
        periodicConnection = nil
    end
end

