local function copyText(text)
	if setclipboard then
		setclipboard(text)
	elseif toclipboard then
		toclipboard(text)
	elseif Clipboard then
		Clipboard(text)
	else
		warn("Clipboard function not available.")
	end
end

local function flash(message, color)
	notif.Text = message
	notif.TextColor3 = color or Color3.fromRGB(170, 255, 170)
	task.delay(1.5, function()
		if notif.Text == message then
			notif.Text = ""
		end
	end)
end

