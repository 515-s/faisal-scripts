-- ========== نظام حفظ الموقع المستمر ==========
local lastPosition = nil

local function updateLastPosition()
	local char = player.Character
	if char then
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if hrp then
			lastPosition = hrp.CFrame
		end
	end
end

-- تحديث الموقع كل 0.05 ثانية
spawn(function()
	while true do
		updateLastPosition()
		task.wait(0.05)
	end
end)

-- 🔹 زر 2 (Collect Cash from Chest) - مع حذف الـ Part وتثبيت قوي
local busy = false

createButton("Collect Cash from Chest", function(selfButton)
	if busy then return end
	busy = true
	selfButton.Text = "Working..."

	-- حذف أي جزء باسم ObbyFailTeleport
	local function deleteTeleportPart()
		local found = false
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj.Name == "ObbyFailTeleport" and obj:IsA("BasePart") then
				obj:Destroy()
				found = true
			end
		end
		return found
	end

	deleteTeleportPart()

	-- استخدام آخر موقع تم حفظه (قبل الضغط بفاصل 0.05 ثانية)
	local originalCFrame = lastPosition
	if not originalCFrame then
		-- احتياط: إذا لم يكن هناك موقع محفوظ، نأخذ الموقع الحالي
		local char = player.Character or player.CharacterAdded:Wait()
		local hrp = char:WaitForChild("HumanoidRootPart")
		originalCFrame = hrp.CFrame
	end

	-- الحصول على الشخصية والأجزاء
	local char = player.Character or player.CharacterAdded:Wait()
	local hrp = char:WaitForChild("HumanoidRootPart")
	local hum = char:FindFirstChildOfClass("Humanoid")

	-- إيقاف الحركة وجعل الشخصية جامدة
	local oldWalk = hum and hum.WalkSpeed or nil
	local oldJump = hum and hum.JumpPower or nil
	local oldPlatform = hum and hum.PlatformStand or nil
	if hum then
		hum.WalkSpeed = 0
		hum.JumpPower = 0
		hum.PlatformStand = true
	end

	task.wait(0.2)

	-- الانتقال إلى الموقعين المطلوبين
	hrp.CFrame = CFrame.new(170, 3, 473)
	task.wait()
	hrp.CFrame = CFrame.new(170, 47, 426)
	task.wait()

	-- العودة إلى الموقع الأصلي مع تثبيت قوي (10 مرات، كل مرة 0.1 ثانية)
	for i = 1, 10 do
		local startTime = tick()
		local connection
		connection = RunService.Heartbeat:Connect(function()
			if tick() - startTime >= 0.1 then
				connection:Disconnect()
				return
			end
			hrp.CFrame = originalCFrame
			if hum then hum.PlatformStand = true end
		end)
		task.wait(0.1)
	end

	-- استعادة الحركة
	if hum then
		hum.WalkSpeed = oldWalk
		hum.JumpPower = oldJump
		hum.PlatformStand = oldPlatform or false
	end

	selfButton.Text = "Collect Cash from Chest"
	busy = false
end)
