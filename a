-- Gib_T Projectile Hijack Silent Aim (مخصص للعبة مع Gib_T bullets)
-- يسرق الـ Gib_T parts ويوجهها للـ target تلقائيًا

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local Debris = game:GetService("Debris")
local Camera = workspace.CurrentCamera

local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

getgenv().GibAim = {
    Enabled = true,
    FOV = 300,
    Smoothing = 0.08,
    Predict = true,
    AutoFire = true
}

-- FOV Indicator
local sg = Instance.new("ScreenGui", game.CoreGui)
local fov = Instance.new("Frame", sg)
fov.Size = UDim2.new(0, GibAim.FOV*2, 0, GibAim.FOV*2)
fov.Position = UDim2.new(0.5, -GibAim.FOV, 0.5, -GibAim.FOV)
fov.BackgroundTransparency = 1
fov.AnchorPoint = Vector2.new(0.5, 0.5)

local circ = Instance.new("ImageLabel", fov)
circ.Size = UDim2.new(1,0,1,0)
circ.BackgroundTransparency = 1
circ.Image = "rbxassetid://4996891970"
circ.ImageTransparency = 0.3
circ.ImageColor3 = Color3.new(0,1,0)
circ.ScaleType = "Fit"

-- Universal Target Finder (أقوى version)
local function FindTarget()
    local bestTarget, bestDist = nil, GibAim.FOV
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not plr.Character or not plr.Character:FindFirstChildOfClass("Humanoid") then continue end
        if plr.Team == LocalPlayer.Team then continue end
        
        -- ابحث عن أي part مناسب (Head, Torso, Arms, Legs, أو أي part كبير)
        for _, part in pairs(plr.Character:GetChildren()) do
            if part:IsA("BasePart") and part.Size.Magnitude > 1.5 and part ~= plr.Character:FindFirstChild("HumanoidRootPart") then
                local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(pos.X, pos.Y)).Magnitude
                    if dist < bestDist then
                        bestTarget = part
                        bestDist = dist
                    end
                end
            end
        end
    end
    return bestTarget
end

local currentTarget = nil

-- MAIN GIB_T HIJACK (السحر هنا!)
local mt = getrawmetatable(game)
local connections = {}

-- Hook على إنشاء Gib_T parts
hookfunction(getrawmetatable(game).__index, function(self, index)
    if index == "Parent" and tostring(self):lower():find("gib_t") then
        -- لقطنا Gib_T part!
        spawn(function()
            if GibAim.Enabled and currentTarget then
                local bullet = self
                local bodyVelocity = Instance.new("BodyVelocity")
                bodyVelocity.MaxForce = Vector3.new(4000, 4000, 4000)
                bodyVelocity.Velocity = (currentTarget.Position - bullet.Position).Unit * 200  -- سرعة الـ bullet
                
                if GibAim.Predict then
                    bodyVelocity.Velocity = (currentTarget.Position + currentTarget.Velocity * 0.1 - bullet.Position).Unit * 200
                end
                
                bodyVelocity.Parent = bullet
                Debris:AddItem(bodyVelocity, 3)
                
                -- Hit effect simulation
                spawn(function()
                    wait(0.1)
                    if bullet.Parent then
                        local hitEffect = Instance.new("Explosion")
                        hitEffect.Position = currentTarget.Position
                        hitEffect.BlastRadius = 0
                        hitEffect.BlastPressure = 0
                        hitEffect.Parent = workspace
                    end
                end)
            end
        end)
    end
    return mt.__index(self, index)
end)

-- Camera aim للـ legit look
RunService.Heartbeat:Connect(function()
    fov.Position = UDim2.new(0.5, Mouse.X-GibAim.FOV, 0.5, Mouse.Y-GibAim.FOV)
    
    if GibAim.Enabled then
        local target = FindTarget()
        if target then
            circ.ImageColor3 = Color3.new(0,1,0)
            circ.ImageTransparency = 0.2
            currentTarget = target
            
            -- Smooth camera
            local tween = TweenService:Create(Camera, TweenInfo.new(GibAim.Smoothing), {CFrame = CFrame.lookAt(Camera.CFrame.Position, target.Position)})
            tween:Play()
            
            -- Auto fire trigger (اضغط mouse1)
            if GibAim.AutoFire and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
                -- Trigger shooting (ابحث عن shoot remote أو fire)
                pcall(function()
                    for _, v in pairs(game.ReplicatedStorage:GetDescendants()) do
                        if v:IsA("RemoteEvent") and (v.Name:lower():find("shoot") or v.Name:lower():find("fire") or v.Name:lower():find("gun")) then
                            v:FireServer(target.Position)
                        end
                    end
                end)
            end
        else
            circ.ImageColor3 = Color3.new(1,0,0)
            circ.ImageTransparency = 0.6
            currentTarget = nil
        end
    else
        circ.ImageTransparency = 1
    end
end)

-- Projectile Velocity Override (backup method)
local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, key)
    if key == "Velocity" and self.Name == "Gib_T" and GibAim.Enabled and currentTarget then
        return (currentTarget.Position - self.Position).Unit * 250
    end
    return oldIndex(self, key)
end)

-- Controls
UserInputService.InputBegan:Connect(function(key)
    if key.KeyCode == Enum.KeyCode.RightControl then
        GibAim.Enabled = not GibAim.Enabled
        print("Gib_T Aim:", GibAim.Enabled and "ACTIVE" or "DISABLED")
    elseif key.KeyCode == Enum.KeyCode.LeftControl then
        GibAim.Smoothing = GibAim.Smoothing == 0.08 and 0.2 or 0.08
        print("Aim Speed toggled:", GibAim.Smoothing)
    end
end)

