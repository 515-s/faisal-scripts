-- LocalScript (StarterPlayerScripts)
-- طريقة محسّنة: نستخدم نسخة محلية (proxy) لشخصيتك + كاميرا محلية Scriptable.
-- مربع أحمر في الوسط: لو دخل لاعب -> تظهر لك كأنك ملتصق على بطنه.

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

-- إعدادات
local BOX_SIZE = UDim2.new(0.25, 0, 0.25, 0)
local BOX_POS  = UDim2.new(0.5, 0, 0.5, 0)
local BOX_ANCHOR = Vector2.new(0.5, 0.5)
local CHECK_RATE = 0 -- 0 => كل فريم، غيّره لـ0.1 مثلاً لتخفيف الفحص
local PROXY_OFFSET = CFrame.new(0, 0.7, 0) -- موضع نسخة اللاعب بالنسبة لبطن الهدف
local CAMERA_OFFSET = Vector3.new(0, 0.9, -0.25) -- مكان الكاميرا نسبة لبطن الهدف (يمكن تعديل)

-- دوال مساعدة بسيطة
local function getBellyPart(character)
    if not character then return nil end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp end
    return character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
end

-- GUI المربع الأحمر
local function createCenterBox()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "CenterRedBoxGui"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = playerGui

    local frame = Instance.new("Frame")
    frame.Name = "RedBox"
    frame.Size = BOX_SIZE
    frame.Position = BOX_POS
    frame.AnchorPoint = BOX_ANCHOR
    frame.BackgroundTransparency = 0.5
    frame.BackgroundColor3 = Color3.fromRGB(200, 30, 30)
    frame.BorderSizePixel = 2
    frame.BorderColor3 = Color3.fromRGB(255, 0, 0)
    frame.ZIndex = 10
    frame.Parent = screenGui

    return frame
end

local redBox = createCenterBox()

-- تحويل موقع العالم لنقطة شاشة وفحص داخل المربع
local function worldPointInFrame(part, frame)
    if not part or not frame or not Camera then return false end
    local vx, vy, vz = Camera:WorldToViewportPoint(part.Position)
    if vz <= 0 then return false end
    local x, y = vx, vy
    local absPos = frame.AbsolutePosition
    local absSize = frame.AbsoluteSize
    if absSize.X == 0 then return false end
    return (x >= absPos.X and x <= absPos.X + absSize.X and y >= absPos.Y and y <= absPos.Y + absSize.Y)
end

-- إخفاء/إظهار جسم اللاعب محليًا (transparent + cancollide false)
local function hideLocalCharacter()
    local char = LocalPlayer.Character
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.LocalTransparencyModifier = 1 -- فقط للعميل
            part.CanCollide = false
        elseif part:IsA("Decal") then
            part.Transparency = 1
        end
    end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.PlatformStand = true -- يمنع اهتزازات غير مرغوبة
    end
end

local function showLocalCharacter()
    local char = LocalPlayer.Character
    if not char then return end
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.LocalTransparencyModifier = 0
            part.CanCollide = true
        elseif part:IsA("Decal") then
            part.Transparency = 0
        end
    end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        humanoid.PlatformStand = false
    end
end

-- إنشاء نسخة محلية خفيفة من شخصيتك (proxy) وتثبيتها لاحقًا
local function createProxy()
    if not LocalPlayer.Character then return nil end
    local proxy = Instance.new("Model")
    proxy.Name = "LocalProxyModel"
    proxy.Parent = Workspace -- نحتفظ بها في Workspace

    -- استنساخ الأجزاء فقط بدون الوظائف (نستخدم Anchored parts)
    for _, obj in pairs(LocalPlayer.Character:GetDescendants()) do
        if obj:IsA("BasePart") then
            local p = obj:Clone()
            p.Transparency = 0
            p.Name = obj.Name
            p.CanCollide = false
            p.Anchored = true
            p.Parent = proxy
        elseif obj:IsA("Accessory") then
            local accClone = obj:Clone()
            accClone.Parent = proxy
            -- عادة الاكسسوارات تحتوي على Handle (BasePart) التي ستُعالج أعلاه
        end
    end

    -- تحديد PrimaryPart (HumanoidRootPart clone)
    local primary = proxy:FindFirstChild("HumanoidRootPart") or proxy:FindFirstChild("UpperTorso") or proxy:FindFirstChild("Torso")
    if primary then
        proxy.PrimaryPart = primary
    end

    return proxy
end

-- تنظيف البروكسي
local function destroyProxy(proxy)
    if proxy and proxy.Parent then
        proxy:Destroy()
    end
end

-- المنطق الرئيسي: تتبع اللاعب داخل المربع وصنع البروكسي والتحكم بالـ camera
local currentTarget = nil
local proxyModel = nil
local lastCheck = 0

RunService.RenderStepped:Connect(function(dt)
    if CHECK_RATE > 0 then
        lastCheck = lastCheck + dt
        if lastCheck < CHECK_RATE then return end
        lastCheck = 0
    end

    if not redBox or redBox.AbsoluteSize.X == 0 then return end

    -- العثور على أول لاعب داخل المربع (حسب بطنه)
    local found = nil
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character.Parent then
            local belly = getBellyPart(p.Character)
            if belly and worldPointInFrame(belly, redBox) then
                found = p
                break
            end
        end
    end

    -- لو دخل لاعب جديد
    if found and found ~= currentTarget then
        -- نظف القديم
        if proxyModel then
            destroyProxy(proxyModel)
            proxyModel = nil
        end
        showLocalCharacter() -- تأكد من إظهار قبل إخفاء جديد لتجنب حالات غريبة

        -- أنشئ البروكسي وخفي جسمك الحقيقي محليًا
        proxyModel = createProxy()
        if proxyModel then
            hideLocalCharacter()
            currentTarget = found
        else
            currentTarget = nil
        end
    end

    -- لو فيه هدف حالياً، حدّث موضع البروكسي و الكاميرا
    if currentTarget and currentTarget.Character and currentTarget.Character.Parent and proxyModel and proxyModel.PrimaryPart then
        local belly = getBellyPart(currentTarget.Character)
        if belly then
            -- ضع نسخة البروكسي عند بطن الهدف + offset
            local targetCFrame = belly.CFrame * PROXY_OFFSET
            proxyModel:SetPrimaryPartCFrame(targetCFrame)

            -- اجعل الكاميرا تنظر من موقع ثابت قريب لبطن الهدف
            Camera.CameraType = Enum.CameraType.Scriptable
            Camera.CFrame = CFrame.new(belly.Position + CAMERA_OFFSET, belly.Position)
        else
            -- لو فقدنا البطن، نفصل
            destroyProxy(proxyModel)
            proxyModel = nil
            showLocalCharacter()
            Camera.CameraType = Enum.CameraType.Custom
            currentTarget = nil
        end

    elseif (not found) and currentTarget then
        -- هدف خرج من المربع: تراجع وننظف
        if proxyModel then destroyProxy(proxyModel); proxyModel = nil end
        showLocalCharacter()
        Camera.CameraType = Enum.CameraType.Custom
        currentTarget = nil
    end
end)

-- تنظيف لو خرجت الشخصية
LocalPlayer.CharacterRemoving:Connect(function()
    if proxyModel then destroyProxy(proxyModel); proxyModel = nil end
    showLocalCharacter()
    Camera.CameraType = Enum.CameraType.Custom
end)
