-- CRACK SCRIPT SOURCE
local function crackSource(scriptObj)
    print("🔓 CRACKING: " .. scriptObj.Name)
    local methods = {
        function() return scriptObj.Source end,
        function()
            if scriptObj:IsA("LocalScript") then
                local func = getfenv(0)[scriptObj.Name]
                return debug.getinfo(func, "S").source or "FUNC_ONLY"
            end
        end,
        function()
            local success, source = pcall(function()
                return scriptObj.Source
            end)
            return success and source or "PCALL_FAIL"
        end
    }
    
    for i, method in pairs(methods) do
        local success, result = pcall(method)
        if success and result and result ~= "" then
            print("✅ CRACKED with method " .. i .. " | Length: " .. #tostring(result))
            return tostring(result)
        end
    end
    
    print("❌ ALL METHODS FAILED")
    return "[[SOURCE PROTECTED - BYPASS FAILED]]"
end

-- Add to output
local function addOutput(text, color)
    color = color or Color3.fromRGB(255, 255, 255)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -10, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = tostring(text)
    label.TextColor3 = color
    label.TextSize = 13
    label.Font = Enum.Font.Code
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Top
    label.TextWrapped = true
    label.Parent = OutputScroll
    
    label.Size = UDim2.new(1, -10, 0, label.TextBounds.Y)
    OutputScroll.CanvasSize = UDim2.new(0, 0, 0, OutputLayout.AbsoluteContentSize.Y)
    
    OutputScroll.CanvasPosition = Vector2.new(0, OutputScroll.CanvasSize.Y.Offset)
end

