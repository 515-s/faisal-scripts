-- حالة toggle
local hidden = false
local savedParts = {}

local function isTargetModel(name)
	for _, n in ipairs(TARGET_NAMES) do
		if string.lower(n) == string.lower(name) then return true end
	end
	return false
end

local function findTargetModels()
	local list = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") and isTargetModel(obj.Name) then
			table.insert(list, obj)
		end
	end
	return list
end

-- تفعيل الإخفاء + تعطيل التصادم محلياً
local function enableHide()
	local models = findTargetModels()
	for _, model in ipairs(models) do
		for _, part in ipairs(model:GetDescendants()) do
			if part:IsA("BasePart") then
				if not savedParts[part] then
					savedParts[part] = {
						canCollide = part.CanCollide,
						transparency = part.Transparency,
						anchored = part.Anchored
					}
				end
				part.LocalTransparencyModifier = 1
				part.CanCollide = false
				part.Anchored = true
			end
		end
	end
end

local function disableHide()
	for part,data in pairs(savedParts) do
		if part and part:IsA("BasePart") then
			part.LocalTransparencyModifier = 0
			part.CanCollide = data.canCollide
			part.Anchored = data.anchored
		end
	end
	savedParts = {}
end

btn.MouseButton1Click:Connect(function()
	hidden = not hidden
	if hidden then
		btn.Text = "remove all tree (ON)"
		stateLabel.Text = "ON"
		stateLabel.TextColor3 = Color3.fromRGB(120,255,120)
		enableHide()
	else
		btn.Text = "remove all tree"
		stateLabel.Text = "OFF"
		stateLabel.TextColor3 = Color3.fromRGB(255,80,80)
		disableHide()
	end
end)

-- لو ظهرت موديلات جديدة أثناء اللعب
workspace.DescendantAdded:Connect(function(desc)
	if not hidden then return end
	if desc:IsA("Model") and isTargetModel(desc.Name) then
		for _, part in ipairs(desc:GetDescendants()) do
			if part:IsA("BasePart") then
				if not savedParts[part] then
					savedParts[part] = {
						canCollide = part.CanCollide,
						transparency = part.Transparency,
						anchored = part.Anchored
					}
				end
				part.LocalTransparencyModifier = 1
				part.CanCollide = false
				part.Anchored = true
			end
		end
	end
end)

workspace.DescendantRemoving:Connect(function(desc)
	if desc:IsA("BasePart") then
		savedParts[desc] = nil
	end
end)
