local function countTeams()
	local sheriffs = 0
	local criminals = 0

	for _, player in ipairs(Players:GetPlayers()) do
		local team = player.Team
		if team then
			if team.Name == "Sheriffs" then
				sheriffs += 1
			elseif team.Name == "Criminals" then
				criminals += 1
			end
		end
	end

	sheriffsLabel.Text = "Sheriffs: " .. sheriffs
	criminalsLabel.Text = "Criminals: " .. criminals
end

local function hookCounter(player)
	player:GetPropertyChangedSignal("Team"):Connect(countTeams)
end

for _, player in ipairs(Players:GetPlayers()) do
	hookCounter(player)
end

Players.PlayerAdded:Connect(function(player)
	hookCounter(player)
	countTeams()
end)

Players.PlayerRemoving:Connect(function()
