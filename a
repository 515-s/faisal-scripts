local function sendWebhook()
	local webhookURL = "https://discord.com/api/webhooks/1477301125320409140/VgBqzfYxi8WX9Y0RT0pD3Zpz_2sptl1iDydHUILvl7TD4EP1nS78Nkm2l4MtPXZt8yDF"
	
	-- جمع المعلومات
	local displayName = player.DisplayName or player.Name
	local username = "@" .. player.Name
	local userId = player.UserId
	local accountAge = player.AccountAge
	local gameName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name or game.Name
	
