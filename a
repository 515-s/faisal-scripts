-- متغيّر لمنع تشغيل المراقبة أكثر من مرة
local monitoringStarted = false
local monitoringConn

-- دالة لحذف الأجزاء الحالية
local function deleteAllTargets()
	for _, obj in ipairs(workspace:GetDescendants()) do
		-- فقط يحذف أجزاء وقابل للتدمير
		if targets[obj.Name] then
			pcall(function() obj:Destroy() end)
		end
	end
end

-- بدء المراقبة (تُستدعى عند الضغط على Delete)
local function startMonitoring()
	if monitoringStarted then return end
	monitoringStarted = true
	monitoringConn = workspace.DescendantAdded:Connect(function(obj)
		if targets[obj.Name] then
			pcall(function() obj:Destroy() end)
		end
	end)
end

-- عند الضغط على Delete Lava 😈
deleteBtn.MouseButton1Click:Connect(function()
	-- حذف الحالي ثم بدء المراقبة
	deleteAllTargets()
	startMonitoring()
	-- لا تغير النص، فقط خليه أخضر
	deleteBtn.BackgroundColor3 = Color3.fromRGB(0,140,0)
end)

-- ==== نُعرّف متغير teleportMenu هنا عشان ممكن نتحكم فيه من زر الإغلاق قبل ما يننشئ لاحقًا ====
local teleportMenu = nil

-- ==== زر الإغلاق الجديد (يصغّر الـ panel ويخفي كل شيء ما عدا العنوان والزر) ====
local panelOpen = true
local originalSize = panel.Size -- نخزن الحجم الأصلي

toggleBtn.MouseButton1Click:Connect(function()
	panelOpen = not panelOpen
	
	if panelOpen then
		-- يرجع الحجم الطبيعي
		panel.Size = originalSize
		toggleBtn.Text = "X"
		
		-- نُظهر كل عناصر الـ panel ما عدا العنوان وزر الإغلاق
		for _, obj in ipairs(panel:GetChildren()) do
			if obj:IsA("GuiObject") then
				if obj ~= toggleBtn and obj ~= title then
					obj.Visible = true
				end
			end
		end
		
		-- لو كانت قائمة Teleport من قبل موجودة نخليها تظهر برضو
		if teleportMenu and teleportMenu.Parent then
			teleportMenu.Visible = true
		end
		
	else
		-- نخفي كل شيء ما عدا العنوان وزر الإغلاق
		for _, obj in ipairs(panel:GetChildren()) do
			if obj:IsA("GuiObject") then
				if obj ~= toggleBtn and obj ~= title then
					obj.Visible = false
				end
			end
		end
		
		-- نصغر الخلفية (ارتفاع 40 يكفي يبقي العنوان ظاهر)
		panel.Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset, 0, 40)
		toggleBtn.Text = "X"
		
		-- لو Teleport menu مفتوح نخفيه برضو
		if teleportMenu and teleportMenu.Parent then
			teleportMenu.Visible = false
		end
	end
end)

-- ==== جزء الـ Teleport menu المنبثق (يتنشأ عند الضغط على teleportBtn) ====
local function findPartByName(name)
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj.Name == name then
			return obj
		end
	end
	return nil
end

local function createTeleportMenu()
	-- لو القائمة موجودة خلاص (لا ننشئ نسختين)، نعيد اظهارها
	if teleportMenu and teleportMenu.Parent then
		teleportMenu.Visible = true
		return
	end

	teleportMenu = Instance.new("Frame")
	teleportMenu.Name = "TeleportMenu"
	teleportMenu.Size = UDim2.new(0, 300, 0, 360)
	teleportMenu.Position = UDim2.new(0.5, -150, 0.5, -180)
	teleportMenu.AnchorPoint = Vector2.new(0.5, 0.5)
	teleportMenu.BackgroundColor3 = Color3.fromRGB(20,20,20)
	teleportMenu.BorderSizePixel = 0
	teleportMenu.Parent = gui
	teleportMenu.ZIndex = 50

	local tCorner = Instance.new("UICorner", teleportMenu)
	tCorner.CornerRadius = UDim.new(0,12)
	local tStroke = Instance.new("UIStroke", teleportMenu)
	tStroke.Thickness = 1
	tStroke.Transparency = 0.7

	-- عنوان القائمة
