-- LocalScript – ضعه في StarterGui (أهم شيء)
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- إعداداتك
local teleportPos = Vector3.new(-15798, 33, -645)
local firstClick = Vector2.new(589, 300)   -- مكان زر فتح نافذة الإهداء
local targetText = "scorv3150"

local virtualInput = game:GetService("VirtualInputManager")

-- 1. الانتقال والتثبيت
rootPart.CFrame = CFrame.new(teleportPos)
humanoid.PlatformStand = true
repeat task.wait() until (rootPart.Position - teleportPos).Magnitude < 5
task.wait(0.5)
print("✅ تم الانتقال والتثبيت")

-- 2. النقر لفتح النافذة
virtualInput:SendMouseButtonEvent(firstClick.X, firstClick.Y, 0, true, game, 0)
task.wait(0.05)
virtualInput:SendMouseButtonEvent(firstClick.X, firstClick.Y, 0, false, game, 0)
task.wait(1.5)  -- انتظر ظهور النافذة
print("✅ تم النقر لفتح النافذة")

-- 3. البحث عن صندوق النص (Username) بكل الطرق الممكنة
local usernameBox = nil

-- الطريقة الأولى: البحث عن كائن اسمه "Username"
for _, gui in ipairs(player.PlayerGui:GetChildren()) do
    local found = gui:FindFirstChild("Username", true)
    if found and found:IsA("TextBox") then
        usernameBox = found
        break
    end
end

-- الطريقة الثانية: البحث عن أول TextBox في النافذة التي ظهرت
if not usernameBox then
    for _, gui in ipairs(player.PlayerGui:GetChildren()) do
        -- ابحث في النافذة التي ظهرت حديثاً (آخر نافذة مضافة)
        local textBoxes = gui:GetDescendants()
        for _, obj in ipairs(textBoxes) do
            if obj:IsA("TextBox") then
                usernameBox = obj
                break
            end
        end
        if usernameBox then break end
    end
end

-- 4. إذا وجدناه، نضع النص مباشرة
if usernameBox then
    usernameBox.Text = targetText
    print("✅ تم لصق النص في صندوق النص: " .. usernameBox.Name)
    print("📝 النص الحالي في الصندوق: " .. usernameBox.Text)
else
    print("❌ لم أجد أي صندوق نص! تأكد من ظهور النافذة.")
    -- طباعة أسماء جميع الـ Gui لمساعدتك
    print("--- قائمة الواجهات الموجودة ---")
    for _, gui in ipairs(player.PlayerGui:GetChildren()) do
        print("GUI:", gui.Name)
        for _, obj in ipairs(gui:GetDescendants()) do
            if obj:IsA("TextBox") then
                print("  → TextBox:", obj.Name)
            end
        end
    end
end
