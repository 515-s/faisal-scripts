local monitoringStarted = false
local monitoringConn

local function deleteAllTargets()
	for _, obj in ipairs(workspace:GetDescendants()) do
		if targets[obj.Name] then
			pcall(function() obj:Destroy() end)
		end
	end
end

local function startMonitoring()
	if monitoringStarted then return end
	monitoringStarted = true
	monitoringConn = workspace.DescendantAdded:Connect(function(obj)
		if targets[obj.Name] then
			pcall(function() obj:Destroy() end)
		end
	end)
end

deleteBtn.MouseButton1Click:Connect(function()
	deleteAllTargets()
	startMonitoring()
	deleteBtn.BackgroundColor3 = Color3.fromRGB(0,140,0)
end)

local teleportMenu = nil
