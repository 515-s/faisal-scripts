-- ===== HELPER FUNCTION FOR LEVEL SETTER =====
local function setPlayerLevel(value)
	local numValue = tonumber(value)
	if not numValue then return false end
	local success = false
	local target = nil
	local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
	if leaderstats then
		for _, child in ipairs(leaderstats:GetChildren()) do
			if child:IsA("ValueBase") and string.lower(child.Name) == "level" then target = child; break end
		end
		if not target then
			for _, child in ipairs(leaderstats:GetChildren()) do
				if child:IsA("ValueBase") and string.find(string.lower(child.Name), "level") then target = child; break end
			end
		end
	end
	if not target then
		for _, child in ipairs(LocalPlayer:GetChildren()) do
			if child:IsA("ValueBase") and string.lower(child.Name) == "level" then target = child; break end
		end
	end
	if not target then
		for _, descendant in ipairs(LocalPlayer:GetDescendants()) do
			if descendant:IsA("ValueBase") and string.lower(descendant.Name) == "level" then target = descendant; break end
		end
	end
	if target then
		pcall(function()
			if target:IsA("NumberValue") or target:IsA("IntValue") or target:IsA("FloatValue") then
				target.Value = numValue
				success = true
			elseif target:IsA("StringValue") then
				target.Value = tostring(numValue)
				success = true
			elseif target:IsA("BoolValue") then
				target.Value = (numValue ~= 0)
				success = true
			end
		end)
	else
		local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
		if leaderstats then
			local newLevel = Instance.new("IntValue")
			newLevel.Name = "Level"
			newLevel.Value = numValue
			newLevel.Parent = leaderstats
			success = true
		end
	end
	return success
end

