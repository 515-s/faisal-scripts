local Players = game:GetService("Players")
local player = Players.LocalPlayer

local rootSaved = nil
local enabled = false

local function getChar()
	return player.Character or player.CharacterAdded:Wait()
end

local function removeRoot()
	local char = getChar()
	local root = char:FindFirstChild("HumanoidRootPart")
	
	if root then
		rootSaved = {
			CFrame = root.CFrame,
			Size = root.Size
		}
		
		root:Destroy()
	end
end

local function restoreRoot()
	local char = getChar()
	if rootSaved then
		
		local newRoot = Instance.new("Part")
		newRoot.Name = "HumanoidRootPart"
		newRoot.Size = rootSaved.Size
		newRoot.CFrame = rootSaved.CFrame
		newRoot.Transparency = 1
		newRoot.CanCollide = false
		newRoot.Anchored = false
		newRoot.Parent = char
		
	end
end

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0,150,0,40)
button.Position = UDim2.new(0,20,0,20)
button.Text = "Destroy Root"
button.Parent = gui

button.MouseButton1Click:Connect(function()

	enabled = not enabled

	if enabled then
		removeRoot()
		button.Text = "Restore Root"
	else
		restoreRoot()
		button.Text = "Destroy Root"
	end

end)
