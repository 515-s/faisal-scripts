local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- قائمة الأسماء اللي نبي نحذفها
local targets = {
	["Fast"] = true,
	["Slow"] = true,
	["Medium"] = true,
	["Very Slow"] = true,
	["Demon"] = true,
	["Extreme"] = true,
	["Insane"] = true,
	["Snake"] = true,
	["HoleInFloor"] = true
}

-- GUI
local gui = Instance.new("ScreenGui")
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 180, 0, 50)
button.Position = UDim2.new(1, -200, 0, 20) -- فوق يمين
button.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
button.TextColor3 = Color3.new(1,1,1)
button.TextScaled = true
button.Text = "حذف الامواج"
button.Parent = gui
button.Active = true
button.Draggable = true

-- عند الضغط على الزر
button.MouseButton1Click:Connect(function()
	-- حذف البارتات الموجودة الآن
	for _, obj in ipairs(workspace:GetDescendants()) do
		if targets[obj.Name] then
			obj:Destroy()
		end
	end

	-- بدء مراقبة أي بارت جديد
	workspace.DescendantAdded:Connect(function(obj)
		if targets[obj.Name] then
			obj:Destroy()
		end
	end)

	-- تعديل الزر بعد الضغط
	button.Text = "تم الحذف ✔ والمراقبة شغالة"
	button.BackgroundColor3 = Color3.fromRGB(0,120,0)
end)
