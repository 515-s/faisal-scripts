-- ✅ Faisal Hub كامل (LocalScript)

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "FaisalHub"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- Frame رئيسي
local main = Instance.new("Frame")
main.Size = UDim2.new(0, 420, 0, 460)
main.Position = UDim2.new(0.5, -210, 0.5, -230)
main.BackgroundColor3 = Color3.fromRGB(78, 32, 120) -- بنفسجي
main.BorderSizePixel = 0
main.Active = true
main.Draggable = true
main.Parent = gui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 18)
corner.Parent = main

local stroke = Instance.new("UIStroke")
stroke.Thickness = 1
stroke.Color = Color3.fromRGB(180, 130, 220)
stroke.Transparency = 0.25
stroke.Parent = main

-- Title
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, -60, 0, 50)
title.Position = UDim2.new(0, 18, 0, 8)
title.BackgroundTransparency = 1
title.Text = "Faisal Hub 🔥"
title.TextColor3 = Color3.fromRGB(255, 240, 255)
title.Font = Enum.Font.GothamBold
title.TextSize = 22
title.TextXAlignment = Enum.TextXAlignment.Left
title.Parent = main

-- زر إغلاق
local close = Instance.new("TextButton")
close.Size = UDim2.new(0, 36, 0, 36)
close.Position = UDim2.new(1, -48, 0, 10)
close.BackgroundColor3 = Color3.fromRGB(255, 194, 224) -- وردي فاتح جدًا
close.Text = "X"
close.TextColor3 = Color3.fromRGB(70, 20, 70)
close.Font = Enum.Font.GothamBold
close.TextSize = 18
close.Parent = main

local closeCorner = Instance.new("UICorner")
closeCorner.CornerRadius = UDim.new(0, 10)
closeCorner.Parent = close

close.MouseButton1Click:Connect(function()
	gui:Destroy()
end)

-- Scroll Frame
local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1, -24, 1, -76)
scroll.Position = UDim2.new(0, 12, 0, 60)
scroll.BackgroundTransparency = 1
scroll.BorderSizePixel = 0
scroll.ScrollBarThickness = 6
scroll.ScrollBarImageColor3 = Color3.fromRGB(255, 210, 235)
scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
scroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
scroll.Parent = main

-- Grid Layout
local grid = Instance.new("UIGridLayout")
grid.CellSize = UDim2.new(0, 180, 0, 56)
grid.CellPadding = UDim2.new(0, 10, 0, 10)
grid.SortOrder = Enum.SortOrder.LayoutOrder
grid.Parent = scroll

-- قائمة السكربتات
local Scripts = {
    {
        Name = "VR7 Script",
        Run = function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/VR7ss/OMK/refs/heads/main/VR7-ON-TOP"))()
        end
    },
    {
        Name = "SkyWars",
        Run = function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/515-s/faisal-scripts/refs/heads/main/SkyWars%20[SEASON%203!]"))()
        end
    },
    {
        Name = "Mouse Coords",
        Run = function()
            loadstring(game:HttpGet("https://pastebin.com/raw/xxxxxxxx"))()
        end
    },
    {
        Name = "Camera Script",
        Run = function()
            loadstring(game:HttpGet("https://pastebin.com/raw/yyyyyyyy"))()
        end
    }
}

-- إنشاء الأزرار
for i, item in ipairs(Scripts) do
	local button = Instance.new("TextButton")
	button.Name = item.Name
	button.LayoutOrder = i
	button.BackgroundColor3 = Color3.fromRGB(255, 214, 234) -- وردي فاتح جدًا
	button.TextColor3 = Color3.fromRGB(85, 25, 85)
	button.Font = Enum.Font.GothamSemibold
	button.TextSize = 15
	button.Text = item.Name
	button.AutoButtonColor = false
	button.Parent = scroll

	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 14)
	btnCorner.Parent = button

	local btnStroke = Instance.new("UIStroke")
	btnStroke.Thickness = 1
	btnStroke.Color = Color3.fromRGB(255, 240, 248)
	btnStroke.Transparency = 0.25
	btnStroke.Parent = button

	button.MouseEnter:Connect(function()
		button.BackgroundColor3 = Color3.fromRGB(255, 228, 240)
	end)

	button.MouseLeave:Connect(function()
		button.BackgroundColor3 = Color3.fromRGB(255, 214, 234)
	end)

	button.MouseButton1Click:Connect(function()
		local ok, err = pcall(item.Run)
		if not ok then
			warn("Button error:", item.Name, err)
		end
	end)
end
