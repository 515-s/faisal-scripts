-- LocalScript (ضعه في StarterGui أو StarterPlayerScripts)
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- إعدادات
local teleportPos = Vector3.new(-15798, 33, -645)
local firstClick = Vector2.new(589, 300)   -- زر فتح الواجهة (عدلها إن لزم)
local targetText = "scorv3150"

local virtualInput = game:GetService("VirtualInputManager")

-- وظيفة الانتقال والتثبيت
local function teleportAndFreeze()
    rootPart.CFrame = CFrame.new(teleportPos)
    humanoid.PlatformStand = true
    repeat task.wait() until (rootPart.Position - teleportPos).Magnitude < 5
    task.wait(0.5)
    print("تم الانتقال والتثبيت")
end

-- وظيفة النقر
local function clickAt(x, y)
    virtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.05)
    virtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
    task.wait(0.2)
end

-- وظيفة البحث عن حقل Username في جميع الواجهات
local function findUsernameTextBox()
    -- ابحث في كل ScreenGui يملكه اللاعب
    for _, gui in ipairs(player.PlayerGui:GetChildren()) do
        -- ابحث بشكل متكرر عن TextBox باسم "Username" أو يحتوي على "username"
        local textBox = gui:FindFirstChild("Username", true)
        if textBox and textBox:IsA("TextBox") then
            return textBox
        end
        -- قد يكون الاسم مختلفاً (مثلاً "TextBox" أو "user")
        local possibleBox = gui:FindFirstChildWhichIsA("TextBox", true)
        if possibleBox then
            -- يمكنك هنا إضافة شرط إضافي مثل: if possibleBox.PlaceholderText == "Username" then
            return possibleBox
        end
    end
    return nil
end

-- وظيفة البحث عن زر Send
local function findSendButton()
    for _, gui in ipairs(player.PlayerGui:GetChildren()) do
        local button = gui:FindFirstChild("Send", true)
        if button and (button:IsA("TextButton") or button:IsA("ImageButton")) then
            return button
        end
    end
    return nil
end

-- التنفيذ
teleportAndFreeze()

-- فتح الواجهة
clickAt(firstClick.X, firstClick.Y)
task.wait(1.5)  -- انتظر ظهور الواجهة

-- البحث عن حقل Username
local usernameBox = findUsernameTextBox()
if usernameBox then
    usernameBox.Text = targetText
    print("تم تعيين النص في حقل Username: " .. targetText)
else
    print("لم يتم العثور على حقل Username! تأكد من ظهور الواجهة.")
end

-- (اختياري) البحث عن زر Send والضغط عليه
task.wait(0.5)
local sendButton = findSendButton()
if sendButton then
    -- محاكاة النقر على الزر
    local absPos = sendButton.AbsolutePosition
    local size = sendButton.AbsoluteSize
    local clickX = absPos.X + size.X / 2
    local clickY = absPos.Y + size.Y / 2
    clickAt(clickX, clickY)
    print("تم الضغط على زر Send")
else
    print("لم يتم العثور على زر Send")
end
