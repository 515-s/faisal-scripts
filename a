-- Dragging for Team Counter
do
	local dragging, dragInput, dragStart, startPos = false
	local function update(input)
		local delta = input.Position - dragStart
		counterFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
	counterFrame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = counterFrame.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	counterFrame.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	RunService.RenderStepped:Connect(function()
		if dragging and dragInput then update(dragInput) end
	end)
end

-- ===== ALL TEAMS TAG SYSTEM =====
local tracked = {}
local function getPart(char) return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart") or char:FindFirstChildWhichIsA("BasePart") end
local function getPlayer(char) return Players:GetPlayerFromCharacter(char) end

local function createTag(plr, char)
	if tracked[char] then return end
	local part = getPart(char)
	if not part then return end
	if char:FindFirstChild("TAG") then tracked[char] = true; return end
	local bb = Instance.new("BillboardGui")
	bb.Name = "TAG"
	bb.Adornee = part
	bb.AlwaysOnTop = true
	bb.Size = UDim2.fromOffset(180,50)
	bb.StudsOffsetWorldSpace = Vector3.new(0,2.8,0)
	bb.Parent = part
	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromScale(1,1)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.TextSize = 18
	label.TextStrokeTransparency = 0.2
	label.TextStrokeColor3 = Color3.new(0,0,0)
	local function update()
		local text = plr.Name
		if plr.Team then text = text .. " [" .. plr.Team.Name .. "]"; label.TextColor3 = plr.TeamColor.Color end
		label.Text = text
	end
	update()
	label.Parent = bb
	local hl = Instance.new("Highlight")
	hl.Adornee = char
	hl.FillTransparency = 0.85
	hl.OutlineTransparency = 0
	hl.Parent = char
	tracked[char] = true
	plr:GetPropertyChangedSignal("Team"):Connect(update)
	char.DescendantAdded:Connect(function()
		local new = getPart(char)
		if new then bb.Adornee = new; bb.Parent = new end
	end)
	char.AncestryChanged:Connect(function(_, p) if not p then tracked[char] = nil end end)
end

local function bind(char)
	task.spawn(function()
		for _ = 1, 100 do
			if not char.Parent then return end
			local p = getPlayer(char)
			local part = getPart(char)
			if p and part then createTag(p, char); return end
			task.wait(0.1)
		end
	end)
end

local function hookTag(plr)
	if plr.Character then bind(plr.Character) end
	plr.CharacterAdded:Connect(bind)
	plr.CharacterAppearanceLoaded:Connect(bind)
	plr:GetPropertyChangedSignal("Team"):Connect(function()
		if plr.Character then tracked[plr.Character] = nil; bind(plr.Character) end
	end)
end
for _, p in ipairs(Players:GetPlayers()) do hookTag(p) end
Players.PlayerAdded:Connect(hookTag)
Workspace.DescendantAdded:Connect(function(inst)
	if inst:IsA("Model") then local p = getPlayer(inst); if p then bind(inst) end end
end)
task.spawn(function()
	while true do
		for _, p in ipairs(Players:GetPlayers()) do
			if p.Character and not tracked[p.Character] then bind(p.Character) end
		end
		task.wait(1.5)
	end
end)

