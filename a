LocalPlayer:GetPropertyChangedSignal("Parent"):Connect(function()
	if not isOnline then return end
	if finalMessageSent then return end
	isOnline = false
	local finalUptime = tick() - scriptStartTime
	sendStatusWebhook("Offline", finalUptime)
	finalMessageSent = true
end)

