-- POWERFUL RECURSIVE SCRIPT SCANNER (same power)
local function scanScripts(parent, path)
    local scripts = {}
    for _, obj in pairs(parent:GetDescendants()) do
        if obj:IsA("LocalScript") or obj:IsA("Script") then
            table.insert(scripts, obj)
        end
    end
    local targets = {
        game:GetService("Workspace"),
        game:GetService("Lighting"),
        game:GetService("ReplicatedStorage"),
        game:GetService("ServerStorage"),
        game:GetService("StarterGui"),
        game:GetService("StarterPack"),
        game:GetService("ReplicatedFirst")
    }
    for _, target in pairs(targets) do
        for _, obj in pairs(target:GetDescendants()) do
            if obj:IsA("LocalScript") or obj:IsA("Script") then
                table.insert(scripts, obj)
            end
        end
    end
    local uniqueScripts = {}
    local seen = {}
    for _, script in pairs(scripts) do
        if not seen[script] then
            seen[script] = true
            table.insert(uniqueScripts, script)
        end
    end
    return uniqueScripts
end

-- Get script source (same power)
local function getScriptSource(scriptObj)
    local success, source = pcall(function()
        if scriptObj.Source then return scriptObj.Source end
        if scriptObj:IsA("LocalScript") then
            local func = scriptObj.Source
            if type(func) == "function" then
                return debug.getinfo(func).source or "Source protected"
            end
        end
        local ok, result = pcall(function()
            return scriptObj.Source or "No source available"
        end)
        return ok and result or "Extraction failed"
    end)
    return success and source or "ERROR: Protected"
end

