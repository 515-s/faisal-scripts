local function setZoom(value)
	local plr = LocalPlayer
	pcall(function() plr.CameraMaxZoomDistance = value end)
	local char = plr.Character
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then pcall(function() hum.CameraMaxZoomDistance = value end) end
	end
	pcall(function() plr:SetAttribute("CameraMaxZoomDistance", value) end)
	local ls = plr:FindFirstChild("leaderstats")
	if ls then
		local v = ls:FindFirstChild("CameraMaxZoomDistance")
		if v and v:IsA("ValueBase") then v.Value = value end
	end
	for _, obj in ipairs(plr:GetDescendants()) do
		if obj.Name == "CameraMaxZoomDistance" and obj:IsA("ValueBase") then
			obj.Value = value
		end
	end
end
