-- ✅ Faisal Hub V2 (LocalScript)

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- 🔹 GUI
local gui = Instance.new("ScreenGui")
gui.Name = "FaisalHub"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- 🔹 Frame رئيسي
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 350, 0, 400)
frame.Position = UDim2.new(0.3, 0, 0.2, 0)
frame.BackgroundColor3 = Color3.fromRGB(20,20,20)
frame.Active = true
frame.Draggable = true
frame.Parent = gui

-- 🔹 Title
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 40)
title.Text = "Faisal Hub 🔥"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundTransparency = 1
title.Font = Enum.Font.GothamBold
title.TextSize = 18
title.Parent = frame

-- 🔹 Scroll Frame
local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1, -10, 1, -80)
scroll.Position = UDim2.new(0, 5, 0, 45)
scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
scroll.ScrollBarThickness = 6
scroll.BackgroundTransparency = 1
scroll.Parent = frame

-- 🔹 Grid Layout (شبكة)
local grid = Instance.new("UIGridLayout")
grid.CellSize = UDim2.new(0, 150, 0, 50)
grid.CellPadding = UDim2.new(0, 10, 0, 10)
grid.Parent = scroll

-- 🔹 قائمة السكربتات
local Scripts = {
    {
        Name = "VR7 Script",
        Url = "https://raw.githubusercontent.com/VR7ss/OMK/refs/heads/main/VR7-ON-TOP"
    },
    {
        Name = "Test 1",
        Url = "https://pastebin.com/raw/xxxxx"
    },
    {
        Name = "Test 2",
        Url = "https://pastebin.com/raw/xxxxx"
    },
    {
        Name = "Test 3",
        Url = "https://pastebin.com/raw/xxxxx"
    }
}

local executed = {}

-- 🔹 إنشاء الأزرار
for _, v in pairs(Scripts) do
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0, 150, 0, 50)
    button.Text = v.Name
    button.BackgroundColor3 = Color3.fromRGB(35,35,35)
    button.TextColor3 = Color3.new(1,1,1)
    button.Font = Enum.Font.Gotham
    button.TextSize = 14
    button.Parent = scroll

    button.MouseButton1Click:Connect(function()
        if executed[v.Url] then return end
        executed[v.Url] = true

        task.spawn(function()
            pcall(function()
                loadstring(game:HttpGet(v.Url))()
            end)
        end)
    end)
end

-- 🔹 تحديث حجم السكرول تلقائي
task.wait()
scroll.CanvasSize = UDim2.new(0, 0, 0, grid.AbsoluteContentSize.Y + 10)

-- 🔹 زر إغلاق
local close = Instance.new("TextButton")
close.Size = UDim2.new(1, 0, 0, 30)
close.Position = UDim2.new(0, 0, 1, -30)
close.Text = "Close"
close.BackgroundColor3 = Color3.fromRGB(80,0,0)
close.TextColor3 = Color3.new(1,1,1)
close.Font = Enum.Font.GothamBold
close.Parent = frame

close.MouseButton1Click:Connect(function()
    gui:Destroy()
end)
