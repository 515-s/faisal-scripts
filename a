-- LocalScript (ضعه في StarterGui)
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- إعداداتك
local teleportPos = Vector3.new(-15798, 33, -645)
local firstClick = Vector2.new(589, 300)   -- زر فتح النافذة
local secondClick = Vector2.new(940, 337)  -- صندوق النص
local textToPaste = "scorv3150"

local virtualInput = game:GetService("VirtualInputManager")
local guiService = game:GetService("GuiService")

-- 1. الانتقال والتثبيت
rootPart.CFrame = CFrame.new(teleportPos)
humanoid.PlatformStand = true
repeat task.wait() until (rootPart.Position - teleportPos).Magnitude < 5
task.wait(0.5)
print("✅ تم الانتقال والتثبيت")

-- 2. النقرة الأولى (فتح النافذة)
virtualInput:SendMouseButtonEvent(firstClick.X, firstClick.Y, 0, true, game, 0)
task.wait(0.05)
virtualInput:SendMouseButtonEvent(firstClick.X, firstClick.Y, 0, false, game, 0)
task.wait(1.5)  -- انتظر ظهور النافذة
print("✅ تم النقرة الأولى (فتح النافذة)")

-- 3. النقرة الثانية (تحديد صندوق النص)
virtualInput:SendMouseButtonEvent(secondClick.X, secondClick.Y, 0, true, game, 0)
task.wait(0.05)
virtualInput:SendMouseButtonEvent(secondClick.X, secondClick.Y, 0, false, game, 0)
task.wait(0.3)
print("✅ تم النقرة الثانية (تحديد الصندوق)")

-- 4. الحصول على الكائن الموجود تحت المؤشر بعد النقرة
local clickedObject = guiService:GetGuiObjectAtPosition(secondClick.X, secondClick.Y)
if clickedObject and clickedObject:IsA("TextBox") then
    clickedObject.Text = textToPaste
    print("✅ تم لصق النص في الصندوق: " .. clickedObject.Name)
    print("📝 النص الحالي: " .. clickedObject.Text)
else
    print("❌ لم يتم العثور على TextBox في الإحداثيات المحددة!")
    if clickedObject then
        print("الكائن الموجود:", clickedObject.Name, "نوعه:", clickedObject.ClassName)
    else
        print("لا يوجد كائن واجهة في تلك الإحداثيات. تأكد من ظهور النافذة وأن الإحداثيات صحيحة.")
    end
end
