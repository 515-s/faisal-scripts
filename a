-- NUCLEAR GIB_T HOMING AIMBOT (Map Delete + Body Lock + Auto-Homing)
-- أقوى حل في التاريخ - كل طلقة تتبع الـ target زي المجنون!

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local PhysicsService = game:GetService("PhysicsService")
local Workspace = workspace

local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
local Camera = Workspace.CurrentCamera

getgenv().NuclearAim = {
    Enabled = true,
    DeleteMap = true,  -- حذف الماب للـ clear sight
    LockBody = true,   -- تثبيت الجسم
    HomingForce = 5000, -- قوة جذب الـ bullets
    FOV = 400
}

print("🚀 NUCLEAR AIMBOT LOADING...")

-- 1. DELETE MAP (Clear Line of Sight)
if NuclearAim.DeleteMap then
    spawn(function()
        for i = 1, 10 do
            for _, obj in pairs(Workspace:GetDescendants()) do
                if obj:IsA("BasePart") and obj.Parent ~= Character and obj.Parent ~= Camera and not obj.Parent:FindFirstChild("Humanoid") then
                    pcall(function() obj:Destroy() end)
                end
            end
            wait(0.1)
        end
        print("🗑️ MAP DELETED - CLEAR SIGHT!")
    end)
end

-- 2. BODY LOCK (PlatformStand + NoClip)
local Humanoid = Character:WaitForChild("Humanoid")
Humanoid.PlatformStand = true
PhysicsService:SetPartCollisionGroup(HumanoidRootPart, "NoCollision")

-- NoClip function
local function NoClip()
    for _, part in pairs(Character:GetChildren()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
end
RunService.Stepped:Connect(NoClip)

-- 3. TARGET FINDER (أقرب player)
local function GetClosestEnemy()
    local closest, dist = nil, NuclearAim.FOV
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local targetPart = player.Character.HumanoidRootPart
            local screenPos, onScreen = Camera:WorldToScreenPoint(targetPart.Position)
            if onScreen then
                local distance = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                if distance < dist then
                    closest = targetPart
                    dist = distance
                end
            end
        end
    end
    return closest
end

-- 4. GIB_T BULLET HOMING (السحر الحقيقي!)
local targetLock = nil
local bulletConnections = {}

-- Monitor ALL new parts (Gib_T أو أي bullet)
Workspace.DescendantAdded:Connect(function(descendant)
    if NuclearAim.Enabled and descendant:IsA("BasePart") and (descendant.Name:find("Gib") or descendant.Name:find("Bullet") or descendant.Name:find("Projectile") or descendant.Size.Magnitude < 2) then
        targetLock = GetClosestEnemy()
        if targetLock then
            -- Homing BodyVelocity
            local bv = Instance.new("BodyVelocity")
            bv.MaxForce = Vector3.new(NuclearAim.HomingForce, NuclearAim.HomingForce, NuclearAim.HomingForce)
            bv.Velocity = (targetLock.Position - descendant.Position).Unit * 300
            
            bv.Parent = descendant
            
            -- Update direction every frame
            local conn
            conn = RunService.Heartbeat:Connect(function()
                if descendant.Parent and targetLock and targetLock.Parent then
                    local newDir = (targetLock.Position + targetLock.Velocity * 0.05 - descendant.Position).Unit
                    bv.Velocity = newDir * 300
                else
                    conn:Disconnect()
                end
            end)
            
            table.insert(bulletConnections, conn)
            
            -- Hit confirmation
            spawn(function()
                wait(0.5)
                if descendant.Position:Distance(targetLock.Position) < 10 then
                    print("🎯 GIB_T HIT CONFIRMED!")
                end
            end)
        end
    end
end)

-- 5. BODY + CAMERA AUTO-AIM
RunService.Heartbeat:Connect(function()
    if NuclearAim.Enabled then
        local target = GetClosestEnemy()
        if target then
            -- Lock body to face target
            if NuclearAim.LockBody then
                HumanoidRootPart.CFrame = CFrame.lookAt(HumanoidRootPart.Position, target.Position)
            end
            
            -- Smooth camera
            local camTween = TweenService:Create(Camera, TweenInfo.new(0.05), {
                CFrame = CFrame.lookAt(Camera.CFrame.Position, target.Position)
            })
            camTween:Play()
            
            -- Auto-shoot trigger
            if UserInputService:IsMouseButtonPressed(1) then
                -- Spam shoot remotes
                for _, rem in pairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
                    if rem:IsA("RemoteEvent") and rem.Name:lower():find("shoot") then
                        rem:FireServer(target.Position)
                    end
                end
            end
        end
    end
end)

-- 6. CONTROLS
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.Insert then
        NuclearAim.Enabled = not NuclearAim.Enabled
        Humanoid.PlatformStand = NuclearAim.Enabled
        print("💥 NUCLEAR AIM:", NuclearAim.Enabled and "ON" or "OFF")
    elseif input.KeyCode == Enum.KeyCode.Delete then
        NuclearAim.DeleteMap = not NuclearAim.DeleteMap
        print("🗑️ Map Delete:", NuclearAim.DeleteMap and "ON" or "OFF")
    end
end)

-- Respawn handler
LocalPlayer.CharacterAdded:Connect(function(newChar)
    Character = newChar
    HumanoidRootPart = newChar:WaitForChild("HumanoidRootPart")
    Humanoid = newChar:WaitForChild("Humanoid")
end)

print("💣 NUCLEAR GIB_T HOMING AIMBOT ACTIVE!")
print("Insert = Toggle | Delete = Map Delete Toggle")
print("🎮 اضغط Mouse1 في أي مكان = الـ Gib_T تروح للـ target!")
print("🗺️ الماب محذوف + جسمك مثبت + bullets homing = GG!")
