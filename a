local scripts = {
	{
		Name = "VR7",
		Run = function()
			print("VR7 button pressed")
		end
	},
	{
		Name = "SkyWars [SEASON 3!] ✨",
		Run = function()
			print("SkyWars button pressed")
		end
	},
	{
		Name = "Test 3",
		Run = function()
			print("Test 3 button pressed")
		end
	},
	{
		Name = "Test 4",
		Run = function()
			print("Test 4 button pressed")
		end
	},
}

local buttons = {}

for i, item in ipairs(scripts) do
	local button = Instance.new("TextButton")
	button.Name = item.Name
	button.LayoutOrder = i
	button.BackgroundColor3 = Color3.fromRGB(255, 214, 234)
	button.TextColor3 = Color3.fromRGB(85, 25, 85)
	button.Font = Enum.Font.GothamSemibold
	button.TextSize = 15
	button.Text = item.Name
	button.AutoButtonColor = false
	button.Parent = buttonsFrame

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 14)
	corner.Parent = button

	local stroke = Instance.new("UIStroke")
	stroke.Thickness = 1
	stroke.Color = Color3.fromRGB(255, 240, 248)
	stroke.Transparency = 0.25
	stroke.Parent = button

	button.MouseEnter:Connect(function()
		button.BackgroundColor3 = Color3.fromRGB(255, 228, 240)
	end)

	button.MouseLeave:Connect(function()
		button.BackgroundColor3 = Color3.fromRGB(255, 214, 234)
	end)

	button.MouseButton1Click:Connect(function()
		local ok, err = pcall(item.Run)
		if not ok then
			warn("Button error:", item.Name, err)
		end
	end)

	buttons[#buttons + 1] = {
		Object = button,
		Name = item.Name
	}
end

-- فلترة البحث
local function applyFilter()
	local query = string.lower(searchText.Text or "")
	for _, info in ipairs(buttons) do
		local visible = (query == "") or string.find(string.lower(info.Name), query, 1, true) ~= nil
		info.Object.Visible = visible
	end
end

searchText:GetPropertyChangedSignal("Text"):Connect(applyFilter)

-- فتح/إغلاق القائمة
local open = true
local function setOpen(state)
	open = state
	main.Visible = state
end

toggle.MouseButton1Click:Connect(function()
	setOpen(not open)
end)
