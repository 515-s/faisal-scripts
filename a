local Workspace = game:GetService("Workspace")

local function isMoving(model)
	for _,v in pairs(model:GetDescendants()) do
		if v:IsA("BasePart") then
			if v.AssemblyLinearVelocity.Magnitude > 0.1 then
				return true
			end
		end
	end
	return false
end

local function disableModel(model)
	for _,v in pairs(model:GetDescendants()) do
		if v:IsA("BasePart") then
			v.CanTouch = false
			v.CanCollide = false
			v.Anchored = true
		elseif v:IsA("Script") or v:IsA("LocalScript") then
			v:Destroy()
		end
	end
end

while true do
	for _,v in pairs(Workspace:GetDescendants()) do
		if v:IsA("Model") and #v.Name > 15 then
			if isMoving(v) then
				disableModel(v)
				pcall(function()
					v:Destroy()
				end)
			end
		end
	end
	task.wait(1)
end
