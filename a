-- Universal Silent Aim + Legit Aimbot + AutoShoot (للألعاب مع random parts)
-- يعمل مع MapleStory R, EMS, وأي shooter مع parts عشوائية

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local Camera = workspace.CurrentCamera

local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

getgenv().AimSettings = {
    Enabled = true,
    TeamCheck = true,
    VisibleCheck = false,  -- false عشان يشتغل مع walls
    FOVRadius = 250,
    TargetDistance = math.huge,
    Smoothing = 0.1,  -- سرعة الـ aim (0.1 = سريع، 1 = بطيء طبيعي)
    AutoShoot = true,
    ShootDistance = 500,  -- مسافة الـ auto shoot
    HitChance = 95,
    PredictMovement = true  -- يتنبأ بحركة الـ target
}

-- FOV Circle
local ScreenGui = Instance.new("ScreenGui", game.CoreGui)
local FOVCircle = Instance.new("Frame", ScreenGui)
FOVCircle.Size = UDim2.new(0, AimSettings.FOVRadius * 2, 0, AimSettings.FOVRadius * 2)
