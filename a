-- LocalScript
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- الإعدادات
local teleportPos = Vector3.new(-15798, 33, -645)
local firstClick = Vector2.new(589, 300)
local secondClick = Vector2.new(940, 337)
local textToPaste = "scorv3150"

local virtualInput = game:GetService("VirtualInputManager")
local guiService = game:GetService("GuiService")

-- 1. الانتقال إلى الموقع
rootPart.CFrame = CFrame.new(teleportPos)
humanoid.PlatformStand = true

-- انتظار وصول اللاعب
repeat task.wait() until (rootPart.Position - teleportPos).Magnitude < 5
task.wait(0.5)

-- 2. النقرة الأولى (فتح الواجهة)
virtualInput:SendMouseButtonEvent(firstClick.X, firstClick.Y, 0, true, game, 0)
task.wait(0.05)
virtualInput:SendMouseButtonEvent(firstClick.X, firstClick.Y, 0, false, game, 0)
task.wait(1) -- انتظر ظهور الواجهة

-- 3. النقرة الثانية على صندوق النص
virtualInput:SendMouseButtonEvent(secondClick.X, secondClick.Y, 0, true, game, 0)
task.wait(0.05)
virtualInput:SendMouseButtonEvent(secondClick.X, secondClick.Y, 0, false, game, 0)
task.wait(0.3)

-- 4. الحصول على صندوق النص تحت المؤشر وتعيين النص مباشرة
local textBox = guiService:GetGuiObjectAtPosition(secondClick.X, secondClick.Y)
if textBox and textBox:IsA("TextBox") then
    textBox.Text = textToPaste
    print("تم تعيين النص بنجاح: " .. textToPaste)
else
    -- إذا لم نجد TextBox، نستخدم الكتابة المباشرة كحل بديل
    virtualInput:SendString(textToPaste)
    print("تمت الكتابة عبر SendString")
end
