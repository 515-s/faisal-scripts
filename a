		walkBox.BackgroundColor3 = Color3.fromRGB(245,245,255)
		walkBox.Parent = p
		Instance.new("UICorner", walkBox)
		walkBox:GetPropertyChangedSignal("Text"):Connect(function()
			local value = tonumber(walkBox.Text)
			if value then
				currentWalkSpeed = value
			end
		end)

		local jumpBox = Instance.new("TextBox")
		jumpBox.Size = UDim2.new(1,-10,0,30)
		jumpBox.Position = UDim2.new(0,5,0,76)
		jumpBox.PlaceholderText = "Jump Power"
		jumpBox.Text = ""
		jumpBox.Font = Enum.Font.GothamBold
		jumpBox.TextSize = 12
		jumpBox.BackgroundColor3 = Color3.fromRGB(245,245,255)
		jumpBox.Parent = p
		Instance.new("UICorner", jumpBox)
		jumpBox:GetPropertyChangedSignal("Text"):Connect(function()
			local value = tonumber(jumpBox.Text)
			if value then
				currentJumpPower = value
			end
		end)

	elseif name == "FAKE" then
		local friendBox = Instance.new("TextBox")
		friendBox.Size = UDim2.new(1,-10,0,30)
		friendBox.Position = UDim2.new(0,5,0,0)
		friendBox.PlaceholderText = "Friend Bonus"
		friendBox.Text = ""
		friendBox.Font = Enum.Font.GothamBold
		friendBox.TextSize = 12
		friendBox.BackgroundColor3 = Color3.fromRGB(245,245,255)
		friendBox.Parent = p
		Instance.new("UICorner", friendBox)
		friendBox:GetPropertyChangedSignal("Text"):Connect(function()
			local value = tonumber(friendBox.Text)
			if not value then return end
			if LocalPlayer:GetAttribute("FriendBonus") ~= nil then
				LocalPlayer:SetAttribute("FriendBonus", value)
			end
		end)

		local levelBox = Instance.new("TextBox")
		levelBox.Size = UDim2.new(1,-10,0,30)
		levelBox.Position = UDim2.new(0,5,0,38)
		levelBox.PlaceholderText = "Level"
		levelBox.Text = ""
		levelBox.Font = Enum.Font.GothamBold
		levelBox.TextSize = 12
		levelBox.BackgroundColor3 = Color3.fromRGB(245,245,255)
		levelBox.Parent = p
		Instance.new("UICorner", levelBox)
		levelBox:GetPropertyChangedSignal("Text"):Connect(function()
			local value = tonumber(levelBox.Text)
			if not value then return end
			setPlayerLevel(value)
		end)
	end
end

