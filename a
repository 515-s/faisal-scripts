	button.LayoutOrder = i
	button.BackgroundColor3 = Color3.fromRGB(255, 214, 234)
	button.TextColor3 = Color3.fromRGB(85, 25, 85)
	button.Font = Enum.Font.GothamSemibold
	button.TextSize = 15
	button.Text = item.Name
	button.AutoButtonColor = false
	button.Parent = scroll

	local btnCorner = Instance.new("UICorner")
	btnCorner.CornerRadius = UDim.new(0, 14)
	btnCorner.Parent = button

	local btnStroke = Instance.new("UIStroke")
	btnStroke.Thickness = 1
	btnStroke.Color = Color3.fromRGB(255, 240, 248)
	btnStroke.Transparency = 0.25
	btnStroke.Parent = button

	button.MouseEnter:Connect(function()
		button.BackgroundColor3 = Color3.fromRGB(255, 228, 240)
	end)

	button.MouseLeave:Connect(function()
		button.BackgroundColor3 = Color3.fromRGB(255, 214, 234)
	end)

	button.MouseButton1Click:Connect(function()
		local ok, err = pcall(item.Run)
		if not ok then
			warn("Button error:", item.Name, err)
		end
	end)
end
