-- ضع هذا السكربت في ServerScriptService أو داخل أداة (Tool) عند تفعيلها

local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

-- دالة لحذف جميع القطع من الخريطة مع استثناء شخصيات اللاعبين
local function deleteAllParts()
    for _, obj in ipairs(Workspace:GetChildren()) do
        -- نتجنب حذف الشخصيات (اللاعبين) لأنها تحتوي على Humanoid
        if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then
            continue
        end
        
        -- إذا كان الكائن قطعة (Part, MeshPart, Union, إلخ) فاحذفه
        if obj:IsA("BasePart") then
            obj:Destroy()
        end
        -- يمكنك إضافة المزيد من الشروط لحذف أنواع أخرى إذا أردت
    end
end

-- دالة لإنشاء قطعة ثابتة أسفل قدم لاعب معين
local function createPartUnderPlayer(player)
    local character = player.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    -- إنشاء قطعة جديدة
    local part = Instance.new("Part")
    part.Name = "GroundPart"
    part.Anchored = true   -- ثابت
    part.Size = Vector3.new(4, 1, 4)   -- حجم مناسب (يمكنك تغييره)
    part.BrickColor = BrickColor.new("Bright red")   -- لون أحمر
    part.Material = Enum.Material.SmoothPlastic
    part.Position = rootPart.Position - Vector3.new(0, rootPart.Size.Y/2 + part.Size.Y/2, 0)
    
    -- وضع القطعة في الخريطة
    part.Parent = Workspace
end

-- تنفيذ الحذف أولاً
deleteAllParts()

-- إنشاء قطعة تحت كل لاعب متصل حالياً
for _, player in ipairs(Players:GetPlayers()) do
    createPartUnderPlayer(player)
end
