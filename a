-- LocalScript لـ StarterPlayerScripts
-- يعرض كاميرا ثانية صغيرة في واجهة اللاعبين (ViewportFrame) تتابع بطن أقرب لاعب
-- الكاميرا الأساسية تبقى بدون تحكم (ما تتغير) — هذا هو الهدف.

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local MainCamera = Workspace.CurrentCamera

-- إعدادات سهلة التعديل
local CHECK_INTERVAL = 0.6 -- يفحص الأقرب كل هالمدة
local VIEWPORT_SIZE = UDim2.new(0.26, 0, 0.26, 0) -- حجم مربع الكاميرا الثانية
local VIEWPORT_POS = UDim2.new(0.72, 0, 0.72, 0) -- مكانه في الشاشة
local PREVIEW_OFFSET = Vector3.new(0, 1, 0.6) -- المسافة خلف البطن في نسخة العرض

-- وظائف مساعدة
local function getBellyPart(character)
    if not character then return nil end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp end
    local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    return torso
end

local function findBestTarget()
    if not LocalPlayer.Character then return nil end
    local myBelly = getBellyPart(LocalPlayer.Character)
    if not myBelly then return nil end

    local bestPlayer, bestDist
    bestDist = math.huge

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character.Parent then
            local belly = getBellyPart(p.Character)
            if belly then
                local d = (belly.Position - myBelly.Position).Magnitude
                if d < bestDist then
                    bestDist = d
                    bestPlayer = p
                end
            end
        end
    end

    return bestPlayer
end

-- بناء واجهة العرض (ViewportFrame)
local function createViewportGui()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "MiniTargetCameraGui"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = playerGui

    local viewport = Instance.new("ViewportFrame")
    viewport.Name = "TargetPreview"
    viewport.Size = VIEWPORT_SIZE
    viewport.Position = VIEWPORT_POS
    viewport.AnchorPoint = Vector2.new(0,0)
    viewport.BackgroundTransparency = 0.35
    viewport.BorderSizePixel = 0
    viewport.BackgroundColor3 = Color3.fromRGB(0,0,0)
    viewport.Parent = screenGui

    return viewport
end

-- توصيل النموذج المعاين مع الشخصية الحقيقية (نقل مواضع الأجزاء كل فريم)
local function setupPreviewModelForCharacter(viewport, character)
    viewport:ClearAllChildren()
    local model = Instance.new("Model")
    model.Name = "PreviewModel"
    model.Parent = viewport

    -- جدول للربط بين الأجزاء الأصلية والنسخ
    local mapping = {}

    for _, obj in pairs(character:GetDescendants()) do
        if obj:IsA("BasePart") then
            local partClone = obj:Clone()
            partClone.CanCollide = false
            partClone.Anchored = true
            partClone.Parent = model
            mapping[obj] = partClone
        elseif obj:IsA("Accessory") then
            -- استنساخ الاكسسوارات ككل (سيشمل الـ Handle الذي هو BasePart)
            local accClone = obj:Clone()
            accClone.Parent = model
            -- الحلقات التالية ستعالج الـ BasePart داخل الاكسسوار إذا لزم
        end
    end

    -- إنشاء كاميرا منفصلة داخل الـ Viewport
    local previewCam = Instance.new("Camera")
    previewCam.Name = "PreviewCamera"
    previewCam.Parent = viewport
    viewport.CurrentCamera = previewCam

    -- دالة لتحديث مواضع نسخة العرض كل فريم
    local updateConn
    updateConn = RunService.RenderStepped:Connect(function()
        if not character.Parent then
            updateConn:Disconnect()
            viewport:ClearAllChildren()
            return
        end

        -- مزامنة كل جزء
        for original, clone in pairs(mapping) do
            if original and clone then
                clone.CFrame = original.CFrame
            end
        end

        -- ضبط كاميرا المعاينة لتكون خلف وبنفس مستوى البطن
        local belly = getBellyPart(character)
        if belly then
            previewCam.CFrame = CFrame.new(belly.Position + PREVIEW_OFFSET, belly.Position)
        end
    end)

    -- نرجع الدوال والـ model علشان نتحكم فيها لاحقًا
    return {
        Model = model,
        Mapping = mapping,
        Camera = previewCam,
        Disconnect = function() if updateConn then updateConn:Disconnect() end end
    }
end

-- المنطق الرئيسي: إنشاء الـ GUI، وفحص الأقرب، وتجهيز المعاينة
local viewport = createViewportGui()
local currentTarget = nil
local currentPreview = nil

spawn(function()
    while true do
        local newTarget = findBestTarget()
        if newTarget ~= currentTarget then
            -- نفصل القديم
            if currentPreview and currentPreview.Disconnect then
                currentPreview.Disconnect()
            end
            viewport:ClearAllChildren()
            viewport.CurrentCamera = nil

            if newTarget and newTarget.Character and newTarget.Character.Parent then
                currentPreview = setupPreviewModelForCharacter(viewport, newTarget.Character)
            else
                currentPreview = nil
            end

            currentTarget = newTarget
        end

        wait(CHECK_INTERVAL)
    end
end)

-- ملاحظات الأداء والاستخدام:
-- • هذا الحل يحافظ على كاميرتك الأساسية كما هي (لا يغير MainCamera).
-- • طريقة العرض تنسخ أجزاء الشخصية (BaseParts) ثم تحافظ على مواضعها بتحديث كل فريم — هذا أقل ثقلاً من استنساخ كل شيء كل فريم، لكنه سيظل يستهلك موارد كلما كانت اللعبة فيها كثير لاعبين.
-- • تقدر تقلل حجم الـ Viewport أو تزيد CHECK_INTERVAL لتحسين الأداء.
-- • إذا تبي الكاميرا تظهر رأس بدل بطن أو تغير المسافة، عدّل getBellyPart أو PREVIEW_OFFSET.

-- انتهى السربت.
