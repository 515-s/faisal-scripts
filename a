-- سكربت لوضع في LocalScript داخل StarterPlayerScripts
-- يثبت الكاميرا على بطن أقرب لاعب غير نفس اللاعب ويُميّز اللاعبين بألوان
-- شرح بسيط بالخطوات داخل التعليقات

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

-- إعدادات: عدّل القيم إذا تبي سلوك مختلف
local CHECK_INTERVAL = 1 -- يفحص كل ثانية من طلبك
local CAMERA_DISTANCE = 8 -- بعد الكاميرا خلف الهدف (يمكن ضبطه)
local CAMERA_HEIGHT = 2 -- ارتفاع الكاميرا فوق بطن الهدف
local SMOOTH_SPEED = 12 -- سرعة تعجيل حركة الكاميرا (أكبر = أسرع)

-- جدول لتخزين Highlight لكل لاعب
local highlights = {}

-- دالة مساعدة لإيجاد جزء "البطن" المناسب (HumanoidRootPart أو Torso)
local function getBellyPart(character)
    if not character then return nil end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp end
    local torso = character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    return torso
end

-- يفحص إذا كان الهدف مخفيًا خلف أي جسم عن الكاميرا
local function isOccluded(targetCharacter)
    local belly = getBellyPart(targetCharacter)
    if not belly then return true end

    local origin = Camera.CFrame.Position
    local direction = belly.Position - origin

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    -- تجاهل جسم اللاعب المحلي عشان ما يتصادم مع نفسه
    if LocalPlayer.Character then
        table.insert(rayParams.FilterDescendantsInstances, LocalPlayer.Character)
    end

    local result = Workspace:Raycast(origin, direction, rayParams)
    if not result then
        -- ما ضرب شي: نعتبره غير محجوب
        return false
    end

    if result.Instance and result.Instance:IsDescendantOf(targetCharacter) then
        return false -- ضرب الهدف نفسه => غير محجوب
    end

    return true -- فيه شيء بين الكاميرا والهدف
end

-- ينشئ أو يرجع Highlight للاعب
local function getOrCreateHighlight(player)
    if highlights[player] and highlights[player].Instance and highlights[player].Instance.Parent then
        return highlights[player].Instance
    end

    local highlight = Instance.new("Highlight")
    highlight.Name = "AutoHighlighter"
    highlight.Adornee = player.Character or nil
    highlight.Enabled = true
    highlight.FillTransparency = 1 -- نخلي الملء شفاف بحيث تبقى فقط الخط الخارجي
    highlight.OutlineTransparency = 0
    highlight.Parent = Camera -- نخليها في الكاميرا أو في PlayerGui

    highlights[player] = { Instance = highlight }
    return highlight
end

-- حدث لأخذ أقرب لاعب (حسب المسافة) مع تفضيل اللاعبين غير المخفيين
local function findBestTarget()
    local bestPlayer = nil
    local bestDistance = math.huge
    if not LocalPlayer.Character then return nil end
    local myBelly = getBellyPart(LocalPlayer.Character)
    if not myBelly then return nil end

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character.Parent then
            local belly = getBellyPart(player.Character)
            if belly then
                local dist = (belly.Position - myBelly.Position).Magnitude
                -- نفضل اللاعبين الظاهرين (غير محجوبين)
                local occluded = isOccluded(player.Character)
                -- معامل للأولوية: اجعل اللاعبين غير المحجوبين أقل قيمة حتى يتفوقوا
                local priorityDist = dist + (occluded and 10000 or 0)
                if priorityDist < bestDistance then
                    bestDistance = priorityDist
                    bestPlayer = player
                end
            end
        end
    end

    return bestPlayer
end

-- تحديث ألوان الـ Highlight لكل اللاعبين: أخضر إذا ظاهر، أحمر إذا مخفي
local function updateHighlights()
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character.Parent then
            local hl = getOrCreateHighlight(player)
            hl.Adornee = player.Character
            local occluded = isOccluded(player.Character)
            if occluded then
                hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop -- يظهر من ورا الجدران
                hl.OutlineColor = Color3.fromRGB(255, 0, 0) -- أحمر
                hl.FillTransparency = 0.9
            else
                hl.DepthMode = Enum.HighlightDepthMode.Occluded -- يظهر طبيعي (أو مختف لو مخفي)
                hl.OutlineColor = Color3.fromRGB(0, 255, 0) -- أخضر
                hl.FillTransparency = 1
            end
        else
            -- إذا اللاعب لا يملك شخصية، نتأكد نحذف الهلايت أو نطفئه
            if highlights[player] and highlights[player].Instance then
                highlights[player].Instance:Destroy()
                highlights[player] = nil
            end
        end
    end
end

-- تحكم بالكاميرا: نجعل الكاميرا تتحرك إلى موضع خلف الهدف وتوجهه نحو بطنه
local targetPlayer = nil
local targetLastSwitch = 0
local cameraTargetCFrame = Camera.CFrame

-- نفحص كل CHECK_INTERVAL لتحديد أفضل هدف، ونحدِّث الهايلايتس
spawn(function()
    while true do
        pcall(function()
            updateHighlights()
            local newTarget = findBestTarget()
            targetPlayer = newTarget
        end)
        wait(CHECK_INTERVAL)
    end
end)

-- نثبت الكاميرا في RenderStepped بحيث تتبع الهدف بسلاسة
RunService.RenderStepped:Connect(function(dt)
    if not Camera then return end

    if targetPlayer and targetPlayer.Character and targetPlayer.Character.Parent then
        local belly = getBellyPart(targetPlayer.Character)
        if belly then
            -- موضع الكاميرا: خلف الهدف بمسافة CAMERA_DISTANCE بالنسبة لاتجاه الكاميرا الحالية
            -- أفضل وضع ثابت: وضع الكاميرا بالنسبة للهدف (مثلاً على محور Z)
            local targetPos = belly.Position
            -- نضع الكاميرا بمقدار ثابت خلف وبمستوى أعلى من بطن الهدف
            local offset = Vector3.new(0, CAMERA_HEIGHT, CAMERA_DISTANCE)
            -- نبي الكاميرا تكون خلف الهدف بالنسبة لاتجاه الكاميرا العالمية (يمكن تعديل)
            local desiredPos = targetPos + Vector3.new(0, CAMERA_HEIGHT, CAMERA_DISTANCE)

            -- نحسب CFrame ينظر مباشرة لبطن الهدف
            local desiredCFrame = CFrame.new(desiredPos, targetPos)

            -- نعالج سلاسة الحركة
            cameraTargetCFrame = cameraTargetCFrame:Lerp(desiredCFrame, math.clamp(SMOOTH_SPEED * dt, 0, 1))
            Camera.CameraType = Enum.CameraType.Scriptable
            Camera.CFrame = cameraTargetCFrame
            return
        end
    end

    -- إذا ما فيه هدف، نخلي الكاميرا على الوضع الحر الافتراضي
    if Camera.CameraType == Enum.CameraType.Scriptable then
        Camera.CameraType = Enum.CameraType.Custom
    end
end)

-- تنظيف عند الخروج
LocalPlayer.AncestryChanged:Connect(function()
    for p, t in pairs(highlights) do
        if t.Instance then t.Instance:Destroy() end
    end
    highlights = {}
end)

-- ملاحظة:
-- • ضع هذا السكربت في StarterPlayerScripts كـ LocalScript.
-- • Highlight يحتاج أن يعمل على العميل (LocalScript) حتى تظهر مؤثرات AlwaysOnTop.
-- • يمكنك تعديل القيم في الأعلى (CHECK_INTERVAL, CAMERA_DISTANCE, CAMERA_HEIGHT) حسب ما تفضّل.
-- • السكربت يحاول تمييز أقرب لاعب ظاهر (أو مخفي إن لم يكن هناك ظاهر) ويجعله هدف الكاميرا.
-- • كن حذرًا عند استخدام تغييرات الكاميرا لأن بعض ألعاب الأونلاين لا تسمح تغييرات الكاميرا أو تحظر من يخترق قوانين اللعبة.
