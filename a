		stateTree.Text = "OFF"
		stateTree.TextColor3 = Color3.fromRGB(255,80,80)
		restoreAll()
	end
end)

-- ===== Auto Tool logic =====
local autoOn = false
local autoThread = nil

local function getAllTools()
	local tools = {}
	-- from Backpack
	local bp = player:FindFirstChild("Backpack")
	if bp then
		for _, item in ipairs(bp:GetChildren()) do
			if item:IsA("Tool") then table.insert(tools, item) end
		end
	end
	-- from Character (equipped)
	local char = player.Character
	if char then
		for _, item in ipairs(char:GetChildren()) do
			if item:IsA("Tool") then table.insert(tools, item) end
		end
	end
	return tools
end

local function tryEquipAndUse(tool)
	if not tool or not tool:IsA("Tool") then return end
	-- ensure character & humanoid
	local char = player.Character or player.CharacterAdded:Wait()
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	-- equip
	pcall(function() humanoid:EquipTool(tool) end)
	-- try activate (client-side). many tools support :Activate() local.
	pcall(function()
		if type(tool.Activate) == "function" then
			tool:Activate()
		end
	end)
end

local function stopUsingTool(tool)
	if not tool or not tool:IsA("Tool") then return end
	pcall(function()
		if type(tool.Deactivate) == "function" then
			tool:Deactivate()
		end
	end)
end

-- تعديل: نستخدم أحدث تول فقط (آخر عنصر في اللست) لو وصل أكثر من تول
local function autoLoop()
	while autoOn do
		local list = getAllTools()
		if #list == 0 then
			-- إذا ما في تولز ننتظر شوي قبل المحاولة مرة ثانية
			wait(1)
		else
			-- نختار أحدث تول (آخر عنصر في القائمة)
			local newest = list[#list]
			if newest and newest.Parent then
				tryEquipAndUse(newest)
				wait(AUTO_TOOL_DELAY)
				stopUsingTool(newest)
			end
		end
		-- فاصل صغير قبل الدورة التالية
		wait(0.2)
	end
end

btnAuto.MouseButton1Click:Connect(function()
	autoOn = not autoOn
	if autoOn then
		btnAuto.Text = BTN_TEXT_AUTO .. " (ON)"
		stateAuto.Text = "ON"
		stateAuto.TextColor3 = Color3.fromRGB(120,255,120)
		-- start loop in coroutine
		if autoThread then
			-- already running? ignore
		else
			autoThread = coroutine.create(function()
				autoLoop()
				autoThread = nil
			end)
			coroutine.resume(autoThread)
		end
	else
		btnAuto.Text = BTN_TEXT_AUTO
		stateAuto.Text = "OFF"
		stateAuto.TextColor3 = Color3.fromRGB(255,80,80)
		-- turning off will end the loop naturally
	end
end)

-- زر Take All Chest: يبحث عن موديلات اسمها "Chest" او "Bundle" وينقلهم داخل جسم اللاعب عند نفس موقعي بالضبط
btnChest.MouseButton1Click:Connect(function()
	local char = player.Character or player.CharacterAdded:Wait()
	local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
	if not hrp then return end

	-- function to move a model so its centroid matches hrp.Position, ثم يعلّق الموديل داخل الشخصية
	local function moveModelToCharacter(model)
		if not model or not model:IsA("Model") then return end
		local parts = {}
		for _, d in ipairs(model:GetDescendants()) do
			if d:IsA("BasePart") then table.insert(parts, d) end
		end
		if #parts == 0 then
			-- لو ما فيه أجزاء، بس نغير البيرنت مكانه
			pcall(function() model.Parent = char end)
			return
		end

		-- نحسب مركز الموديل (centroid)
		local sum = Vector3.new(0,0,0)
		for _, p in ipairs(parts) do sum = sum + p.Position end
		local centroid = sum / #parts
		local delta = hrp.Position - centroid

		-- نحرّك كل جزء بمقدار delta
		for _, p in ipairs(parts) do
			pcall(function()
				p.CFrame = p.CFrame + delta
			end)
		end

		-- أخيرا نخلي الموديل داخل شخصية اللاعب
		pcall(function() model.Parent = char end)
	end

	-- نجمع كل الموديلات المطابقة (case-insensitive لأسماء Chest أو Bundle)
	local found = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("Model") then
			local nm = obj.Name and string.lower(obj.Name) or ""
			if nm == "chest" or nm == "bundle" then
				table.insert(found, obj)
			end
		end
	end

	-- نحرك كلهم
	for _, m in ipairs(found) do
		pcall(function()
			moveModelToCharacter(m)
		end)
	end
end)

