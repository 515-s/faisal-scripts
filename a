local function notify(title, text)
	task.spawn(function()
		for _ = 1, 10 do
			local ok = pcall(function()
				StarterGui:SetCore("SendNotification", {
					Title = title,
					Text = text,
					Duration = 9
				})
			end)
			if ok then
				return
			end
			task.wait(0.5)
		end
	end)
end

local function copy(text)
	pcall(function()
		if typeof(setclipboard) == "function" then
			setclipboard(text)
		end
	end)
end

