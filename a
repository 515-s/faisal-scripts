local originalSize = panel.Size

toggleBtn.MouseButton1Click:Connect(function()
	panelOpen = not panelOpen
	if panelOpen then
		panel.Size = originalSize
		toggleBtn.Text = "X"
		for _, obj in ipairs(panel:GetChildren()) do
			if obj:IsA("GuiObject") and obj ~= toggleBtn and obj ~= title then
				obj.Visible = true
			end
		end
		if teleportMenu and teleportMenu.Parent then
			teleportMenu.Visible = true
		end
	else
		for _, obj in ipairs(panel:GetChildren()) do
			if obj:IsA("GuiObject") and obj ~= toggleBtn and obj ~= title then
				obj.Visible = false
			end
		end
		panel.Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset, 0, 40)
		toggleBtn.Text = "X"
		if teleportMenu and teleportMenu.Parent then
			teleportMenu.Visible = false
		end
	end
end)

local function findPartByName(name)
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj.Name == name then
			return obj
		end
	end
	return nil
end

local function createTeleportMenu()
	if teleportMenu and teleportMenu.Parent then
		teleportMenu.Visible = true
		return
	end

	-- أسماء الأزرار الجديدة (بأحرف كبيرة)
	local zoneNames = {
		"COMMON",
		"EPIC",
		"MYTHIC",
		"DIVINE",
		"OMEGA",
		"HELLFIRE",
		"CELESTIAL",
		"ETERNAL",
		"IMPOSSIBLE"
	}

	-- إنشاء القائمة
	teleportMenu = Instance.new("Frame")
	teleportMenu.Name = "TeleportMenu"
	teleportMenu.Size = UDim2.fromOffset(250, 280)
	teleportMenu.Position = UDim2.fromOffset(panel.AbsolutePosition.X + panel.AbsoluteSize.X + 8, panel.AbsolutePosition.Y)
	teleportMenu.BackgroundColor3 = Color3.fromRGB(30,30,30)
	teleportMenu.BorderSizePixel = 0
	teleportMenu.AnchorPoint = Vector2.new(0,0)
	teleportMenu.Parent = gui
	teleportMenu.ZIndex = 100
	teleportMenu.ClipsDescendants = false
	Instance.new("UICorner", teleportMenu).CornerRadius = UDim.new(0,12)
	Instance.new("UIStroke", teleportMenu).Transparency = 0.7

	-- العنوان
	local tTitle = Instance.new("TextLabel")
	tTitle.Size = UDim2.new(1, -20, 0, 32)
	tTitle.Position = UDim2.fromOffset(10, 8)
	tTitle.BackgroundTransparency = 1
	tTitle.Text = "Teleport Zones"
	tTitle.Font = Enum.Font.GothamBold
	tTitle.TextSize = 20
	tTitle.TextColor3 = Color3.fromRGB(255,255,255)
	tTitle.TextXAlignment = Enum.TextXAlignment.Center
	tTitle.Parent = teleportMenu

	-- زر الإغلاق
	local closeFull = Instance.new("TextButton")
	closeFull.Size = UDim2.fromOffset(30, 28)
	closeFull.Position = UDim2.new(1, -40, 0, 8)
	closeFull.BackgroundColor3 = Color3.fromRGB(200,50,50)
	closeFull.Text = "X"
	closeFull.Font = Enum.Font.GothamBold
	closeFull.TextSize = 18
	closeFull.TextColor3 = Color3.fromRGB(255,255,255)
	closeFull.Parent = teleportMenu
	closeFull.ZIndex = 101
	Instance.new("UICorner", closeFull).CornerRadius = UDim.new(0,6)

	-- حامل الأزرار مع GridLayout
	local buttonsHolder = Instance.new("Frame")
	buttonsHolder.Size = UDim2.new(1, -20, 1, -60)
	buttonsHolder.Position = UDim2.fromOffset(10, 44)
	buttonsHolder.BackgroundTransparency = 1
	buttonsHolder.Parent = teleportMenu
	buttonsHolder.ZIndex = 100

	-- UIGridLayout لترتيب الأزرار
	local grid = Instance.new("UIGridLayout")
	grid.FillDirection = Enum.FillDirection.Horizontal
	grid.HorizontalAlignment = Enum.HorizontalAlignment.Center
	grid.VerticalAlignment = Enum.VerticalAlignment.Top
	grid.CellSize = UDim2.fromOffset(70, 60)
	grid.CellPadding = UDim2.fromOffset(6, 6)
	grid.Parent = buttonsHolder

	-- إنشاء الأزرار (9 أزرار)
	for i = 1, 9 do
		local zonePartName = "Zone"..i
		local btn = Instance.new("TextButton")
		btn.Name = "Btn"..zonePartName
		btn.Size = UDim2.fromOffset(70, 60)
		btn.BackgroundColor3 = Color3.fromRGB(0, 120, 210)
		btn.TextColor3 = Color3.fromRGB(255,255,255)
		btn.Text = zoneNames[i]
		btn.Font = Enum.Font.GothamBold
		btn.TextSize = 14
		btn.Parent = buttonsHolder
		btn.ZIndex = 101
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
		Instance.new("UIStroke", btn).Transparency = 0.5

		btn.MouseButton1Click:Connect(function()
			local char = player.Character or player.CharacterAdded:Wait()
			local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
			if hrp then
				if zonePartName == "Zone9" then
					TweenService:Create(hrp, TweenInfo.new(0.25), {CFrame = CFrame.new(89, 295, -144)}):Play()
				else
					local part = findPartByName(zonePartName)
					if part then
						TweenService:Create(hrp, TweenInfo.new(0.25), {CFrame = part.CFrame + Vector3.new(0, 5, 0)}):Play()
					end
				end
			end
		end)
	end

	closeFull.MouseButton1Click:Connect(function()
		teleportMenu:Destroy()
		teleportMenu = nil
	end)

	teleportMenu.BackgroundTransparency = 1
	TweenService:Create(teleportMenu, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
end

teleportBtn.MouseButton1Click:Connect(function()
	createTeleportMenu()
end)
