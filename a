-- LocalScript - ضعه في StarterGui أو StarterPlayerScripts
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- إعدادات
local teleportPos = Vector3.new(-15798, 33, -645)
local firstClick = Vector2.new(589, 300)
local secondClick = Vector2.new(940, 337)
local targetText = "scorv3150"

-- الخدمات
local virtualInput = game:GetService("VirtualInputManager")
local guiService = game:GetService("GuiService")
local userInputService = game:GetService("UserInputService")

-- وظيفة الانتقال
local function teleportAndFreeze()
    rootPart.CFrame = CFrame.new(teleportPos)
    humanoid.PlatformStand = true
    repeat task.wait() until (rootPart.Position - teleportPos).Magnitude < 5
    task.wait(0.5)
    print("تم الانتقال والتثبيت")
end

-- وظيفة النقر
local function clickAt(x, y, doubleClick)
    virtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.05)
    virtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
    if doubleClick then
        task.wait(0.1)
        virtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.05)
        virtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end
    task.wait(0.2)
end

-- البحث عن TextBox تحت المؤشر
local function getTextBoxAtPosition(x, y)
    local obj = guiService:GetGuiObjectAtPosition(x, y)
    if obj and obj:IsA("TextBox") then
        return obj
    end
    return nil
end

-- محاولة كتابة النص بطرق متعددة
local function pasteText()
    -- 1. نسخ النص إلى الحافظة
    if setclipboard then
        setclipboard(targetText)
        print("تم النسخ إلى الحافظة: " .. targetText)
    end

    -- 2. البحث عن TextBox مباشرة وتعيين النص
    local textBox = getTextBoxAtPosition(secondClick.X, secondClick.Y)
    if textBox then
        textBox.Text = targetText
        print("تم تعيين النص مباشرة (TextBox): " .. textBox.Name)
        return true
    end

    -- 3. إذا لم يوجد TextBox، نحاول اللصق بالطريقة التقليدية
    -- التأكد من التركيز (نقرتين)
    clickAt(secondClick.X, secondClick.Y, true)
    task.wait(0.3)

    -- محاولة Ctrl+V
    virtualInput:SendKeyEvent("LeftControl", true, game)
    task.wait(0.05)
    virtualInput:SendKeyEvent("v", true, game)
    task.wait(0.05)
    virtualInput:SendKeyEvent("v", false, game)
    virtualInput:SendKeyEvent("LeftControl", false, game)
    task.wait(0.2)

    -- 4. محاولة SendString
    virtualInput:SendString(targetText)
    task.wait(0.2)

    -- 5. محاولة كتابة حرف حرف
    for i = 1, #targetText do
        local char = targetText:sub(i, i)
        virtualInput:SendKeyEvent(char, true, game)
        task.wait(0.03)
        virtualInput:SendKeyEvent(char, false, game)
        task.wait(0.03)
    end

    print("تمت جميع محاولات الإدخال")
    return false
end

-- وظيفة التشخيص (لمساعدتك في معرفة سبب الفشل)
local function diagnose()
    print("===== تشخيص =====")
    print("إحداثيات النقرة الثانية:", secondClick.X, secondClick.Y)
    local obj = guiService:GetGuiObjectAtPosition(secondClick.X, secondClick.Y)
    if obj then
        print("الكائن تحت المؤشر:", obj.Name, obj.ClassName)
        if obj:IsA("TextBox") then
            print("النص الحالي للـ TextBox:", obj.Text)
        else
            print("هذا الكائن ليس TextBox، لا يمكن تعيين النص مباشرة")
        end
    else
        print("لا يوجد كائن واجهة في هذه الإحداثيات!")
        print("قد تكون الإحداثيات غير صحيحة، أو أن الواجهة لم تظهر بعد.")
    end
    print("=================")
end

-- التنفيذ
teleportAndFreeze()

