local Players = game:GetService("Players")
local PhysicsService = game:GetService("PhysicsService")

local player = Players.LocalPlayer
local enabled = false

pcall(function()
	PhysicsService:CreateCollisionGroup("NoHitbox")
end)

PhysicsService:CollisionGroupSetCollidable("NoHitbox","Default",false)

local function setHitbox(state)

	local char = player.Character
	if not char then return end

	for _,v in pairs(char:GetDescendants()) do
		if v:IsA("BasePart") then
			
			if state then
				PhysicsService:SetPartCollisionGroup(v,"NoHitbox")
				v.CanTouch = false
				v.CanCollide = false
			else
				PhysicsService:SetPartCollisionGroup(v,"Default")
				v.CanTouch = true
				v.CanCollide = true
			end

		end
	end

end

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0,150,0,40)
button.Position = UDim2.new(0,20,0,20)
button.Text = "Hitbox OFF"
button.Parent = gui

button.MouseButton1Click:Connect(function()

	enabled = not enabled

	if enabled then
		setHitbox(true)
		button.Text = "Hitbox ON"
	else
		setHitbox(false)
		button.Text = "Hitbox OFF"
	end

end)
