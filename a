-- دالة الحذف والمراقبة
local function startDeletion()
	-- حذف الموجود
	for _, obj in ipairs(workspace:GetDescendants()) do
		if targets[obj.Name] then
			obj:Destroy()
		end
	end
	-- مراقبة جديد
	workspace.DescendantAdded:Connect(function(obj)
		if targets[obj.Name] then
			obj:Destroy()
		end
	end)
	deleteBtn.Text = "تم الحذف ✔ والمراقبة شغالة"
	deleteBtn.BackgroundColor3 = Color3.fromRGB(0,140,0)
end

deleteBtn.MouseButton1Click:Connect(startDeletion)
