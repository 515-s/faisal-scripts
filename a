local Players = game:GetService("Players")
local player = Players.LocalPlayer

local fakeRoot
local enabled = false

local function getChar()
	return player.Character or player.CharacterAdded:Wait()
end

local function removeRoot()

	local char = getChar()
	local root = char:FindFirstChild("HumanoidRootPart")
	local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")

	if root and torso then

		fakeRoot = Instance.new("Part")
		fakeRoot.Size = Vector3.new(2,2,1)
		fakeRoot.Transparency = 1
		fakeRoot.Anchored = false
		fakeRoot.CanCollide = false
		fakeRoot.CFrame = root.CFrame
		fakeRoot.Parent = char

		local weld = Instance.new("WeldConstraint")
		weld.Part0 = torso
		weld.Part1 = fakeRoot
		weld.Parent = fakeRoot

		root:Destroy()
	end

end

local function restoreRoot()

	local char = getChar()
	local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")

	if torso and fakeRoot then

		local root = Instance.new("Part")
		root.Name = "HumanoidRootPart"
		root.Size = Vector3.new(2,2,1)
		root.Transparency = 1
		root.CanCollide = false
		root.CFrame = fakeRoot.CFrame
		root.Parent = char

		local weld = Instance.new("WeldConstraint")
		weld.Part0 = torso
		weld.Part1 = root
		weld.Parent = root

		fakeRoot:Destroy()
		fakeRoot = nil
	end

end

-- GUI
local gui = Instance.new("ScreenGui")
gui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0,150,0,40)
button.Position = UDim2.new(0,20,0,20)
button.Text = "Destroy Root"
button.Parent = gui

button.MouseButton1Click:Connect(function()

	enabled = not enabled

	if enabled then
		removeRoot()
		button.Text = "Restore Root"
	else
		restoreRoot()
		button.Text = "Destroy Root"
	end

end)
