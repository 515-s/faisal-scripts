	tTitle.Parent = teleportMenu

	-- زر اغلاق كامل داخل القائمة (يخفي/يُدمر القائمة)
	local closeFull = Instance.new("TextButton")
	closeFull.Size = UDim2.new(0, 28, 0, 26)
	closeFull.Position = UDim2.new(1, -36, 0, 8)
	closeFull.BackgroundColor3 = Color3.fromRGB(110,110,110)
	closeFull.Text = "X"
	closeFull.Font = Enum.Font.GothamBold
	closeFull.TextSize = 18
	closeFull.TextColor3 = Color3.fromRGB(255,255,255)
	closeFull.Parent = teleportMenu
	Instance.new("UICorner", closeFull).CornerRadius = UDim.new(0,6)

	-- حاوية لأزرار الـ Zones
	local buttonsHolder = Instance.new("Frame")
	buttonsHolder.Size = UDim2.new(1, -16, 1, -60)
	buttonsHolder.Position = UDim2.new(0,8,0,44)
	buttonsHolder.BackgroundTransparency = 1
	buttonsHolder.Parent = teleportMenu

	-- ننشئ 9 أزرار Zone1..Zone9 بتصميم شبكي 3x3
	local rows = 3
	local cols = 3
	local pad = 8
	local btnW = (buttonsHolder.AbsoluteSize.X - (pad*(cols+1))) / cols
	-- لكن لأن AbsoluteSize قد يكون صفر عند الإنشاء، نستخدم مقاسات نسبية
	local spacingX = 0.32
	local spacingY = 0.28

	for i = 1, 9 do
		local r = math.floor((i-1)/cols)
		local c = (i-1) % cols
		local zoneName = "Zone"..tostring(i)

		local zBtn = Instance.new("TextButton")
		zBtn.Name = "Btn"..zoneName
		zBtn.Size = UDim2.new(0.3, 0, 0, 80)
		zBtn.Position = UDim2.new(0.05 + (c * 0.32), 0, 0 + (r * 0.32), 0)
		zBtn.BackgroundColor3 = Color3.fromRGB(45,45,45)
		zBtn.TextColor3 = Color3.fromRGB(255,255,255)
		zBtn.Text = zoneName
		zBtn.Font = Enum.Font.Gotham
		zBtn.TextSize = 18
		zBtn.Parent = buttonsHolder
		Instance.new("UICorner", zBtn).CornerRadius = UDim.new(0,8)
		local zStroke = Instance.new("UIStroke", zBtn)
		zStroke.Transparency = 0.7

		-- عند الضغط على زر الـ Zone
		zBtn.MouseButton1Click:Connect(function()
			local part = findPartByName(zoneName)
			if part then
				-- محاولة نقل اللاعب لأعلى الجزء بقليل لتجنب التصادم
				local char = player.Character or player.CharacterAdded:Wait()
				local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
				if hrp then
					-- نستخدم Tween لتحريك ناعم (اختياري)
					local goal = {CFrame = part.CFrame + Vector3.new(0, 5, 0)}
					pcall(function()
						TweenService:Create(hrp, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), goal):Play()
					end)
				end
			else
				-- لو ما لقينا الجزء ما نعمل شيء (ما نعرض رسائل حسب طلبك)
			end
		end)
	end

	-- زر إغلاق كامل (يدمر القائمة)
	closeFull.MouseButton1Click:Connect(function()
		if teleportMenu then
			teleportMenu:Destroy()
			teleportMenu = nil
		end
	end)

	-- دخول ناعم (Tween) عند الظهور
	teleportMenu.BackgroundTransparency = 1
	TweenService:Create(teleportMenu, TweenInfo.new(0.18), {BackgroundTransparency = 0}):Play()
end

-- عند ضغط زر teleport: ننشئ أو نُعيد اظهار القائمة
teleportBtn.MouseButton1Click:Connect(function()
	createTeleportMenu()
end)

