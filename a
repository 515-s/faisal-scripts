-- Universal Target Finder (يصيد random parts)
local function GetBestTarget()
    local BestTarget = nil
    local BestDistance = AimSettings.FOVRadius

    for _, Player in pairs(Players:GetPlayers()) do
        if Player == LocalPlayer or not Player.Character or not Player.Character:FindFirstChild("Humanoid") or Player.Character.Humanoid.Health <= 0 then continue end
        
        if AimSettings.TeamCheck and Player.Team == LocalPlayer.Team then continue end

        -- Universal Part Detection: أي part كبير متحرك مش منك
        local BodyParts = {}
        for _, Part in pairs(Player.Character:GetChildren()) do
            if Part:IsA("BasePart") and Part.Name ~= "HumanoidRootPart" and Part.Size.Magnitude > 1 and Part.Parent == Player.Character then
                table.insert(BodyParts, Part)
            end
        end
        
        if #BodyParts == 0 then continue end

        local ClosestPart = nil
        local ClosestScreenDistance = math.huge

        for _, Part in pairs(BodyParts) do
            local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
            if OnScreen then
                local ScreenDistance = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(ScreenPos.X, ScreenPos.Y)).Magnitude
                if ScreenDistance < ClosestScreenDistance then
                    ClosestPart = Part
                    ClosestScreenDistance = ScreenDistance
                end
            end
        end

        if ClosestPart and ClosestScreenDistance < BestDistance then
            BestTarget = ClosestPart
            BestDistance = ClosestScreenDistance
        end
    end

    return BestTarget
end

-- Smooth Camera Aim
local CurrentTarget = nil
local TweenInfo = TweenInfo.new(AimSettings.Smoothing, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

RunService.Heartbeat:Connect(function()
    FOVCircle.Position = UDim2.new(0.5, Mouse.X - AimSettings.FOVRadius, 0.5, Mouse.Y - AimSettings.FOVRadius)
    
    if not AimSettings.Enabled then 
        Circle.ImageTransparency = 1
        CurrentTarget = nil
        return 
    end

    local Target = GetBestTarget()
    if Target then
        Circle.ImageTransparency = 0.2
        Circle.ImageColor3 = Color3.fromRGB(0, 255, 0)
        
        CurrentTarget = Target
        
        -- Predict Movement
        local Prediction = AimSettings.PredictMovement and Target.Velocity * 0.1 or Vector3.new()
        local PredictedPos = Target.Position + Prediction
        
        -- Smooth Camera Look
        local CameraTween = TweenService:Create(Camera, TweenInfo, {CFrame = CFrame.lookAt(Camera.CFrame.Position, PredictedPos)})
        CameraTween:Play()
        
        -- Auto Shoot
        if AimSettings.AutoShoot and (LocalPlayer.Character.HumanoidRootPart.Position - Target.Position).Magnitude <= AimSettings.ShootDistance then
            if math.random(1, 100) <= AimSettings.HitChance then
                -- Fire الـ remotes الشائعة (عدل حسب الـ game)
                local args = {PredictedPos}
                pcall(function()
                    game.ReplicatedStorage.DefaultChatSystemChatEvents.SayMessageRequest:FireServer("", "all")
                    -- أو RemoteEvent:FireServer("Shoot", PredictedPos) إذا معروف
                end)
            end
        end
    else
        Circle.ImageTransparency = 0.6
        Circle.ImageColor3 = Color3.fromRGB(255, 0, 0)
        CurrentTarget = nil
    end
end)

-- Silent Aim Hook (للـ raycasts العادية كـ backup)
local mt = getrawmetatable(game)
local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if AimSettings.Enabled and CurrentTarget and self.Parent and method == "FireServer" and string.find(string.lower(tostring(self.Name)), "shoot") then
        args[1] = CurrentTarget.Position
        return oldNamecall(self, unpack(args))
    end
    
    return oldNamecall(self, unpack(args))
end)

-- Controls
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    if input.KeyCode == Enum.KeyCode.RightShift then
        AimSettings.Enabled = not AimSettings.Enabled
        print("Universal Aim:", AimSettings.Enabled and "ON" or "OFF")
    elseif input.KeyCode == Enum.KeyCode.LeftShift then
        AimSettings.Smoothing = AimSettings.Smoothing == 0.1 and 0.3 or 0.1  -- Toggle speed
        print("Aim Speed:", AimSettings.Smoothing)
    end
end)

