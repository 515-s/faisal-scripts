-- LocalScript (يضعه في StarterGui أو StarterPlayerScripts)

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- 1. نقل اللاعب إلى الموقع المطلوب
local targetPosition = Vector3.new(-15798, 33, -645)
rootPart.CFrame = CFrame.new(targetPosition)

-- 2. تثبيت اللاعب (منع الحركة)
humanoid.PlatformStand = true

-- 3. انتظار حتى يصل اللاعب إلى الموقع
local function waitForTeleport()
    while true do
        if (rootPart.Position - targetPosition).Magnitude < 5 then
            break
        end
        task.wait(0.1)
    end
end

waitForTeleport()

-- 4. محاكاة نقرة على الشاشة عند الإحداثيات المحددة
task.wait(0.5) -- تأخير بسيط للتأكد

local userInputService = game:GetService("UserInputService")
local virtualInput = game:GetService("VirtualInputManager")

-- إحداثيات النقر
local screenX = 589
local screenY = 300

-- محاكاة النقر (إذا كان مدعوماً)
virtualInput:SendMouseButtonEvent(screenX, screenY, 0, true, game, 0)
task.wait(0.05)
virtualInput:SendMouseButtonEvent(screenX, screenY, 0, false, game, 0)

print("تم الانتقال والنقر على الإحداثيات:", screenX, screenY)
