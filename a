do
	local dragging = false
	local dragInput
	local dragStart
	local startPos

	local function update(input)
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end

	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then

			dragging = true
			dragStart = input.Position
			startPos = frame.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	frame.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	RunService.RenderStepped:Connect(function()
		if dragging and dragInput then
			update(dragInput)
		end
	end)
end

-- ===== TAG SYSTEM =====

local tracked = {}

local function getPart(char)
	return char:FindFirstChild("Head")
		or char:FindFirstChild("HumanoidRootPart")
		or char:FindFirstChildWhichIsA("BasePart")
end

local function getPlayer(char)
	return Players:GetPlayerFromCharacter(char)
end

local function createTag(player, char)
	if tracked[char] then return end

	local part = getPart(char)
	if not part then return end

	if char:FindFirstChild("TAG") then
		tracked[char] = true
		return
	end

	local bb = Instance.new("BillboardGui")
	bb.Name = "TAG"
	bb.Adornee = part
	bb.AlwaysOnTop = true
	bb.Size = UDim2.fromOffset(180,50)
	bb.StudsOffsetWorldSpace = Vector3.new(0,2.8,0)
	bb.Parent = part

	local label = Instance.new("TextLabel")
	label.Size = UDim2.fromScale(1,1)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.GothamBold
	label.TextSize = 18
	label.TextStrokeTransparency = 0.2
	label.TextStrokeColor3 = Color3.new(0,0,0)

	local function update()
		local text = player.Name
		if player.Team then
			text = text .. " [" .. player.Team.Name .. "]"
			label.TextColor3 = player.TeamColor.Color
		end
		label.Text = text
	end

	update()
	label.Parent = bb

	local hl = Instance.new("Highlight")
	hl.Adornee = char
	hl.FillTransparency = 0.85
	hl.OutlineTransparency = 0
	hl.Parent = char

	tracked[char] = true

	player:GetPropertyChangedSignal("Team"):Connect(update)

	char.DescendantAdded:Connect(function()
		local new = getPart(char)
		if new then
			bb.Adornee = new
			bb.Parent = new
		end
	end)

	char.AncestryChanged:Connect(function(_, p)
		if not p then
			tracked[char] = nil
		end
	end)
end

local function bind(char)
	task.spawn(function()
		for i = 1, 100 do
			if not char.Parent then return end

			local player = getPlayer(char)
			local part = getPart(char)

			if player and part then
				createTag(player, char)
				return
			end

			task.wait(0.1)
		end
	end)
end

local function hook(player)
	if player.Character then
		bind(player.Character)
	end

	player.CharacterAdded:Connect(bind)

	player.CharacterAppearanceLoaded:Connect(function(char)
		bind(char)
	end)

	player:GetPropertyChangedSignal("Team"):Connect(function()
		if player.Character then
			tracked[player.Character] = nil
			bind(player.Character)
		end
	end)
end

for _, p in ipairs(Players:GetPlayers()) do
	hook(p)
end

Players.PlayerAdded:Connect(hook)

Workspace.DescendantAdded:Connect(function(inst)
	if inst:IsA("Model") then
		local p = getPlayer(inst)
		if p then
			bind(inst)
		end
	end
end)

task.spawn(function()
	while true do
		for _, p in ipairs(Players:GetPlayers()) do
			if p.Character and not tracked[p.Character] then
				bind(p.Character)
			end
		end
		task.wait(1.5)
	end
end)

-- ===== ANTI FALL SYSTEM =====

local Lobby = Workspace:FindFirstChild("Lobby")
if not Lobby then return end

local Obby = Lobby:FindFirstChild("Obby")
if not Obby then return end

local FallingPlatforms = Obby:FindFirstChild("FallingPlatforms")
if not FallingPlatforms then return end

local antiFallFolder = Instance.new("Folder")
antiFallFolder.Name = "anti_fall"
antiFallFolder.Parent = Obby

local function getAllParts(model)
	local parts = {}
	local function scan(parent)
		for _, child in ipairs(parent:GetChildren()) do
			if child:IsA("BasePart") then
				table.insert(parts, child)
			end
			if child:IsA("Model") or child:IsA("Folder") then
				scan(child)
			end
		end
	end
	scan(model)
	return parts
end

local originalParts = getAllParts(FallingPlatforms)
if #originalParts == 0 then
	antiFallFolder:Destroy()
	return
end

for _, oldPart in ipairs(originalParts) do
	local newPart = Instance.new("Part")
	newPart.Name = oldPart.Name .. "_static"
	newPart.CFrame = oldPart.CFrame
	newPart.Size = oldPart.Size
	newPart.Color = Color3.fromRGB(134, 188, 255)
	newPart.Material = Enum.Material.DiamondPlate
	newPart.Anchored = true
	newPart.CanCollide = true
	newPart.Transparency = 0
	newPart.Parent = antiFallFolder
end

FallingPlatforms:Destroy()

Players.PlayerRemoving:Connect(function(plr)
	if plr == LocalPlayer then
		sendOnExit()
	end
end)
