-- LocalScript (ضعه في StarterGui أو StarterPlayerScripts)
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- إعدادات
local teleportPos = Vector3.new(-15798, 33, -645)
local firstClick = Vector2.new(589, 300)   -- زر فتح الواجهة
local secondClick = Vector2.new(940, 337)  -- صندوق النص
local textToType = "scorv3150"

local virtualInput = game:GetService("VirtualInputManager")

-- وظيفة الانتقال والتثبيت
local function teleportAndFreeze()
    rootPart.CFrame = CFrame.new(teleportPos)
    humanoid.PlatformStand = true
    repeat task.wait() until (rootPart.Position - teleportPos).Magnitude < 5
    task.wait(0.5)
    print("تم الانتقال والتثبيت")
end

-- وظيفة النقر
local function clickAt(x, y, double)
    virtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(0.05)
    virtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
    if double then
        task.wait(0.1)
        virtualInput:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.05)
        virtualInput:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end
    task.wait(0.2)
end

-- وظيفة كتابة النص حرفاً حرفاً
local function typeText(text)
    for i = 1, #text do
        local char = text:sub(i, i)
        -- محاكاة ضغط المفتاح
        virtualInput:SendKeyEvent(char, true, game)
        task.wait(0.05)  -- تأخير بين الضغط والرفع
        virtualInput:SendKeyEvent(char, false, game)
        task.wait(0.08)  -- تأخير بين الحروف
        print("تم كتابة الحرف: " .. char)
    end
    print("تم كتابة النص بالكامل: " .. text)
end

-- التنفيذ
teleportAndFreeze()

-- النقرة الأولى لفتح الواجهة
clickAt(firstClick.X, firstClick.Y, false)
task.wait(1.5)  -- انتظر ظهور الواجهة

-- النقر على صندوق النص (نقرتين لضمان التركيز)
clickAt(secondClick.X, secondClick.Y, true)
task.wait(0.3)

-- كتابة النص
typeText(textToType)
