local targetNames = {
	"Cheak_Parent",
	"Cheak_Fly",
	"Cheak_Prop",
	"Cheak_Vars",
	"TpLoop",
	"Kick",
	"otherScript",
	"Token_Create",
	"Token_Cheak",
	"Cheak_HitBox"
}

-- تحويل لقاموس لسرعة البحث
local nameMap = {}
for _, name in ipairs(targetNames) do
	nameMap[name] = true
end

local function renameMatches()
	for _, obj in ipairs(game:GetDescendants()) do
		if nameMap[obj.Name] then
			if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
				obj.Name = "i dont know"
			end
		end
	end
end

-- تشغيل أولي
renameMatches()

-- متابعة أي ريموت جديد
game.DescendantAdded:Connect(function(obj)
	if nameMap[obj.Name] then
		if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
			obj.Name = "i dont know"
		end
	end
end)
